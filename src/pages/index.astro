---
import Base from '~/layouts/Base.astro';
import { getSeriesHighlights } from '~/lib/collections';

const enHighlights = await getSeriesHighlights('en');
const highlights = enHighlights.length > 0 ? enHighlights : await getSeriesHighlights('ko');
const highlightLang: 'en' | 'ko' = enHighlights.length > 0 ? 'en' : 'ko';
const writingBase = highlightLang === 'ko' ? '/ko/writing' : '/writing';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Chaesang Jung',
  alternateName: '정채상',
  url: 'https://ieumtech.net/',
  sameAs: 'https://linkedin.com/in/chaesang',
  description: 'Thirty years in IT, between Korea and Silicon Valley.',
};
---
<Base
  title="Chaesang Jung · 정채상 — Ieum"
  description="Thirty years in IT, between Korea and Silicon Valley. A place for what has been learned along the way."
  ogTitle="Chaesang Jung · 정채상"
  ogDescription="Thirty years in IT, between Korea and Silicon Valley."
  lang="en"
  path="/"
  ogType="profile"
  jsonLd={jsonLd}
  altLangPath="/ko/"
>
  <style slot="head" is:inline>
    .hero-inner { padding: 24px 24px 16px; max-width: 640px; margin: 0 auto; }
    .hero-profile { margin-bottom: 20px; }
    .hero-profile img { border-radius: 50%; width: 128px; height: 128px; object-fit: cover; }
    .hero-name { font-size: 2.25rem; font-weight: 600; margin: 0 0 4px; color: var(--color-text); letter-spacing: -0.025em; }
    .hero-name-en { font-size: 0.9375rem; color: var(--color-muted); margin: 0 0 24px; }
    .hero-intro p { font-size: 1rem; line-height: 1.75; color: var(--color-text); margin: 0 0 14px; }
    .hero-intro p:last-child { margin-bottom: 0; }

    .recent-writing { padding: 40px 0; border-top: 1px solid var(--color-border); }
    .recent-writing-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 20px; }
    .recent-writing-header h2 { margin: 0; font-size: 1.5rem; }
    .recent-writing-all { font-size: 0.875rem; color: var(--color-muted); text-decoration: none; }
    .recent-writing-all:hover { color: var(--color-accent); }
    .recent-writing-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px; }
    .recent-writing-item { padding: 12px 0; border-top: 1px solid var(--color-border); }
    .recent-writing-series { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; text-decoration: none; color: var(--color-text); }
    .recent-writing-series:hover .recent-writing-series-title { color: var(--color-accent); }
    .recent-writing-series-title { font-size: 1rem; font-weight: 600; }
    .recent-writing-count { font-size: 0.8125rem; color: var(--color-muted); flex-shrink: 0; }
    .recent-writing-desc { font-size: 0.875rem; color: var(--color-muted); margin: 6px 0 10px; line-height: 1.6; }
    .recent-writing-latest { font-size: 0.9375rem; color: var(--color-text); text-decoration: none; display: inline-block; }
    .recent-writing-latest:hover { color: var(--color-accent); }
  </style>

  <section class="hero" id="home">
    <div class="hero-inner">
      <div class="hero-profile">
        <img src="/profile.jpg" alt="Chaesang Jung" width="96" height="96" loading="lazy" />
      </div>
      <h1 class="hero-name">Chaesang Jung</h1>
      <p class="hero-name-en">정채상</p>
      <div class="hero-intro">
        <p>Thirty years in IT, between Korea and Silicon Valley.</p>
        <p>Working between people and technology through the changes,</p>
        <p>and keeping what has been learned along the way here.</p>
      </div>
    </div>
  </section>

  <main>
    {highlights.length > 0 && (
      <section class="recent-writing">
        <div class="container">
          <div class="recent-writing-header">
            <h2>Writing — Several Threads</h2>
            <a href={writingBase} class="recent-writing-all">All writing →</a>
          </div>
          <ul class="recent-writing-list">
            {highlights.map(({ meta, count, latest }) => {
              const latestSlug = latest.slug.split('/').pop()!;
              const title = meta.data.titles[highlightLang] ?? meta.data.slug;
              const desc = meta.data.descriptions[highlightLang];
              return (
                <li class="recent-writing-item">
                  <a class="recent-writing-series" href={`${writingBase}/series/${meta.data.slug}`}>
                    <span class="recent-writing-series-title">{title}</span>
                    <span class="recent-writing-count">{count} {count === 1 ? 'entry' : 'entries'}</span>
                  </a>
                  {desc && <p class="recent-writing-desc">{desc}</p>}
                  <a class="recent-writing-latest" href={`${writingBase}/${latestSlug}`}>
                    → {latest.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      </section>
    )}

    <section class="cta-section" id="contact" aria-labelledby="cta-heading">
      <div class="cta-inner">
        <h2 class="cta-heading" id="cta-heading">If there's a thread worth pulling on, let's pull on it together.</h2>
        <div class="cta-buttons">
          <a href="mailto:hello@ieumtech.net" class="btn">Email</a>
          <a href="https://linkedin.com/in/chaesang" target="_blank" rel="noopener noreferrer" class="btn btn-outline">LinkedIn</a>
        </div>
      </div>
    </section>
  </main>
</Base>
