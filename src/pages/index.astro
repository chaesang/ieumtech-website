---
import Base from '~/layouts/Base.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Chaesang Jung',
  alternateName: '정채상',
  url: 'https://ieumtech.net/',
  sameAs: 'https://linkedin.com/in/chaesang',
  description: 'Thirty years — between Korea and Silicon Valley, and between people and technology.',
};
---
<Base
  title="Chaesang Jung · 정채상 — Ieum"
  description="Thirty years in IT, between Korea and Silicon Valley. A place for what has been learned along the way."
  ogTitle="Chaesang Jung · 정채상"
  ogDescription="Thirty years in IT, between Korea and Silicon Valley."
  lang="en"
  path="/"
  ogType="profile"
  jsonLd={jsonLd}
  altLangPath="/ko/"
>
  <style slot="head" is:inline>
    /* Hero */
    .hero {
      background: var(--color-surface);
      padding: var(--space-9) 0 var(--space-8);
      text-align: left;
    }
    .hero-inner {
      max-width: var(--container-max);
      margin: 0 auto;
      padding: 0 var(--container-padding);
    }
    .hero-head {
      display: flex;
      align-items: flex-start;
      gap: var(--space-5);
      margin-bottom: var(--space-5);
    }
    .hero-avatar img {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      object-fit: cover;
    }
    .hero-text {
      flex: 1;
      min-width: 0;
    }
    .hero-name {
      font-size: 1.875rem;
      font-weight: 600;
      letter-spacing: -0.025em;
      line-height: 1.15;
      margin: 0 0 2px;
      color: var(--color-text);
    }
    .hero-name-en {
      font-size: 0.875rem;
      color: var(--color-muted);
      margin: 0 0 var(--space-3);
    }
    .hero-bio {
      font-size: 1rem;
      line-height: 1.75;
      color: var(--color-text);
      margin: 0 0 var(--space-5);
    }
    .breadth {
      font-size: 0.8125rem;
      color: var(--color-muted);
      line-height: 1.8;
      margin: 0 0 var(--space-5);
    }
    .breadth-row {
      display: flex;
      gap: var(--space-4);
    }
    .breadth-label {
      color: var(--color-subtle);
      min-width: 56px;
      flex-shrink: 0;
    }
    .breadth-values {
      flex: 1;
    }
    .hero-now {
      font-size: 1rem;
      line-height: 1.7;
      color: var(--color-text);
      margin: 0;
    }

    /* Anchor Grid */
    .anchor-grid-section {
      padding: var(--space-10) 0;
    }
    .anchor-grid-inner {
      max-width: var(--container-max);
      margin: 0 auto;
      padding: 0 var(--container-padding);
    }
    .anchor-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4);
    }
    .anchor-card {
      display: block;
      padding: var(--space-5);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      text-decoration: none;
      color: inherit;
      transition: border-color var(--transition-fast), background var(--transition-fast);
    }
    .anchor-card:hover {
      border-color: var(--color-accent);
      background: var(--color-surface);
    }
    .anchor-card:hover .anchor-title {
      color: var(--color-accent);
    }
    .anchor-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-text);
      margin-bottom: 4px;
      transition: color var(--transition-fast);
    }
    .anchor-hint {
      font-size: 0.875rem;
      color: var(--color-muted);
      line-height: 1.6;
    }

    /* Soft Contact */
    .cta-section {
      background: var(--color-bg);
    }
    .contact-tags {
      font-size: 0.875rem;
      color: var(--color-muted);
      margin-bottom: var(--space-5);
      letter-spacing: 0.02em;
    }

    @media (max-width: 639px) {
      .anchor-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <section class="hero" id="home">
    <div class="hero-inner">
      <div class="hero-head">
        <div class="hero-avatar">
          <img src="/profile.jpg" alt="Chaesang Jung" width="80" height="80" loading="lazy" />
        </div>
        <div class="hero-text">
          <h1 class="hero-name">Chaesang Jung</h1>
          <p class="hero-name-en">정채상</p>
        </div>
      </div>
      <p class="hero-bio">Thirty years — between Korea and Silicon Valley, and between people and technology.</p>
      <div class="breadth" aria-label="Career overview">
        <div class="breadth-row">
          <span class="breadth-label">Roles</span>
          <span class="breadth-values">Software engineer / Tech lead / People manager / Product manager / Technical advisor / Leadership / Adjunct Professor</span>
        </div>
        <div class="breadth-row">
          <span class="breadth-label">Domains</span>
          <span class="breadth-values">Embedded / Smartphone / Consumer service / Tech infrastructure / Big Data / AI</span>
        </div>
      </div>
      <p class="hero-now">Still learning, sharing, and connecting — wherever the chance arises.</p>
    </div>
  </section>

  <main>
    <section class="anchor-grid-section" aria-label="Site navigation">
      <div class="anchor-grid-inner">
        <div class="anchor-grid">
          <a href="/companies" class="anchor-card">
            <div class="anchor-title">Places I've Worked</div>
            <div class="anchor-hint">A trail across thirty years</div>
          </a>
          <a href="/writing" class="anchor-card">
            <div class="anchor-title">Writing</div>
            <div class="anchor-hint">Several series, ongoing</div>
          </a>
          <a href="/talks" class="anchor-card">
            <div class="anchor-title">Talks</div>
            <div class="anchor-hint">Lectures, keynotes, classroom hours</div>
          </a>
          <a href="/about" class="anchor-card">
            <div class="anchor-title">About</div>
            <div class="anchor-hint">A three-minute read</div>
          </a>
        </div>
      </div>
    </section>

    <section class="cta-section" id="contact" aria-labelledby="cta-heading">
      <div class="cta-inner">
        <p class="contact-tags">Advising · speaking · conversation</p>
        <h2 class="cta-heading" id="cta-heading">If there's a thread worth pulling on, let's pull on it together.</h2>
        <div class="cta-buttons">
          <a href="mailto:hello@ieumtech.net" class="btn">Email</a>
          <a href="https://linkedin.com/in/chaesang" target="_blank" rel="noopener noreferrer" class="btn btn-outline">LinkedIn</a>
        </div>
      </div>
    </section>
  </main>
</Base>
