---
import { getCollection } from 'astro:content';
import Base from '~/layouts/Base.astro';

export async function getStaticPaths() {
  const en = await getCollection('companies', (e) => !e.data.draft && e.data.lang === 'en');
  const ko = await getCollection('companies', (e) => !e.data.draft && e.data.lang === 'ko');
  const all = new Map<string, (typeof en)[number]>();
  for (const e of ko) all.set(e.slug.split('/').pop()!, e);
  for (const e of en) all.set(e.slug.split('/').pop()!, e); // en overrides
  const ordered = Array.from(all.entries())
    .map(([slug, entry]) => ({ slug, entry }))
    .sort((a, b) => b.entry.data.period.start.valueOf() - a.entry.data.period.start.valueOf());
  return ordered.map(({ slug, entry }, idx) => {
    const prev = ordered[idx - 1]?.entry ?? null;
    const next = ordered[idx + 1]?.entry ?? null;
    const prevSlug = ordered[idx - 1]?.slug ?? null;
    const nextSlug = ordered[idx + 1]?.slug ?? null;
    return { params: { slug }, props: { entry, prev, next, prevSlug, nextSlug } };
  });
}

const { entry, prev, next, prevSlug, nextSlug } = Astro.props;
const { Content } = await entry.render();
const fmt = (d: Date) => `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}`;
const start = entry.data.period.start;
const end = entry.data.period.end;
const period = end ? `${fmt(start)} – ${fmt(end)}` : `${fmt(start)} – Present`;
---
<Base
  title={`${entry.data.name} — Places I've Worked — Chaesang Jung`}
  description={entry.data.summary ?? `${entry.data.name} — ${entry.data.role}`}
  lang="en"
  path={`/companies/${entry.slug.split('/').pop()}`}
  ogType="article"
  altLangPath={`/ko/companies/${entry.slug.split('/').pop()}`}
>
  <main>
    <article class="company-detail">
      <div class="detail-inner">
        <nav class="breadcrumb"><a href="/companies">← Places I've Worked</a></nav>
        <header class="detail-header">
          <div class="meta">
            <span class="period">{period}</span>
          </div>
          <h1>{entry.data.name}</h1>
          <p class="role">{entry.data.role}</p>
          {entry.data.summary && <p class="summary">{entry.data.summary}</p>}
        </header>
        <div class="prose">
          <Content />
        </div>
        {entry.data.links && entry.data.links.length > 0 && (
          <aside class="links">
            <h3>Links</h3>
            <ul>
              {entry.data.links.map((l) => (
                <li><a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a></li>
              ))}
            </ul>
          </aside>
        )}
        {(prev || next) && (
          <nav class="adj-nav" aria-label="Previous and next company">
            <a
              class={`adj-nav-item ${prev ? '' : 'disabled'}`}
              href={prev ? `/companies/${prevSlug}` : undefined}
              aria-disabled={prev ? undefined : 'true'}
            >
              <span class="adj-nav-dir">← Previous (more recent)</span>
              {prev && <span class="adj-nav-name">{prev.data.name}</span>}
            </a>
            <a
              class={`adj-nav-item ${next ? '' : 'disabled'}`}
              href={next ? `/companies/${nextSlug}` : undefined}
              aria-disabled={next ? undefined : 'true'}
            >
              <span class="adj-nav-dir">Next (earlier) →</span>
              {next && <span class="adj-nav-name">{next.data.name}</span>}
            </a>
          </nav>
        )}
      </div>
    </article>
  </main>
</Base>

<style>
  .company-detail { padding: 32px 0 56px; }
  .detail-inner { max-width: 640px; margin: 0 auto; padding: 0 24px; }
  .breadcrumb { margin-bottom: 24px; font-size: 0.875rem; }
  .breadcrumb a { color: var(--color-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); }
  .detail-header { margin-bottom: 32px; border-bottom: 1px solid var(--color-border); padding-bottom: 24px; }
  .meta { font-size: 0.8125rem; color: var(--color-muted); margin-bottom: 12px; }
  .detail-header h1 { font-size: 1.875rem; margin: 0 0 8px; letter-spacing: -0.02em; }
  .role { font-size: 1rem; color: var(--color-muted); margin: 0 0 12px; }
  .summary { font-size: 1rem; line-height: 1.7; color: var(--color-text); margin: 0; }
  .prose { font-size: 1rem; line-height: 1.8; color: var(--color-text); }
  .prose :global(h2) { font-size: 1.25rem; font-weight: 600; margin: 32px 0 12px; }
  .prose :global(p) { margin: 0 0 16px; }
  .prose :global(ul) { padding-left: 24px; margin: 0 0 16px; }
  .links { margin-top: 32px; padding: 16px 0; border-top: 1px solid var(--color-border); }
  .links h3 { font-size: 0.875rem; font-weight: 600; margin: 0 0 8px; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.06em; }
  .links ul { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 4px; }
  .links a { color: var(--color-accent); }

  .adj-nav { margin-top: 48px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .adj-nav-item { display: flex; flex-direction: column; gap: 6px; padding: 16px; background: #fff; border: 1px solid var(--color-border); border-radius: 8px; color: var(--color-text); text-decoration: none; transition: border-color 0.15s, transform 0.15s; }
  .adj-nav-item:last-child { text-align: right; }
  .adj-nav-item:hover:not(.disabled) { border-color: var(--color-accent); }
  .adj-nav-item:hover:not(.disabled) .adj-nav-name { color: var(--color-accent); }
  .adj-nav-item.disabled { opacity: 0.4; pointer-events: none; cursor: default; }
  .adj-nav-dir { font-size: 0.75rem; color: var(--color-muted); letter-spacing: 0.02em; }
  .adj-nav-name { font-size: 0.9375rem; font-weight: 600; }
  @media (max-width: 480px) { .adj-nav { grid-template-columns: 1fr; } .adj-nav-item:last-child { text-align: left; } }
</style>
