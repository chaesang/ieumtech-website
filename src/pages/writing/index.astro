---
import Base from '~/layouts/Base.astro';
import {
  getPublishedWriting,
  getActiveSeriesWithMeta,
  getWritingBySeries,
} from '~/lib/collections';

const enEntries = await getPublishedWriting('en');
const isKoFallback = enEntries.length === 0;
const displayLang: 'ko' | 'en' = isKoFallback ? 'ko' : 'en';

const seriesList = await getActiveSeriesWithMeta(displayLang);
const seriesWithEntries = await Promise.all(
  seriesList.map(async ({ meta, count, latestDate }) => {
    const entries = await getWritingBySeries(meta.data.slug, displayLang);
    return { meta, count, entries, latestDate };
  })
);

const allEntries = await getPublishedWriting(displayLang);
const uncategorized = allEntries.filter((e) => !e.data.series);

const dateLabel = (d: Date) =>
  d.toLocaleDateString(displayLang === 'ko' ? 'ko-KR' : 'en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });

const sourceLabel = (source: string): string => {
  if (source === 'brunch') return 'Brunch';
  if (source === 'nia') return 'NIA';
  if (source === 'dbr') return 'DBR';
  if (source === 'linkedin') return 'LinkedIn';
  return '';
};

const seriesIcons: Record<string, string> = {
  'svc-analysis': 'search',
  'do-well-company': 'building-2',
  'itterm': 'book-open',
  '90s-com-eng': 'save',
  'chaesang-priv': 'pen-line',
  'dfmba-recom': 'graduation-cap',
  'kaist-dfmba-24': 'graduation-cap',
  'kaist-dfmba-25': 'graduation-cap',
  'chaesang-etc': 'sparkles',
  'chaesang-it-26': 'lightbulb',
};
---
<Base
  title="Writing — Chaesang Jung | Ieum Tech"
  description="Essays and contributed pieces, gathered by series. Most pieces first published on Brunch (in Korean); English translations are gradually being added."
  lang="en"
  path="/writing"
  ogType="website"
  altLangPath="/ko/writing"
>
  <main>
    <section class="list-hero">
      <div class="container">
        <h1>Writing</h1>
        <p class="list-lead">Thinking out loud, reflecting on experience, and sharing lessons learned along the way.</p>
        {isKoFallback && (
          <p class="notice">
            Currently in Korean. English translations are planned but not yet published.
          </p>
        )}
      </div>
    </section>

    <section class="list-body">
      <div class="container">
        <ol class="series-list">
          {seriesWithEntries.map(({ meta, count, entries, latestDate }) => {
            const title = meta.data.titles[displayLang] ?? meta.data.titles.ko;
            const description = meta.data.descriptions[displayLang];
            const initial = title.charAt(0);
            const iconName = seriesIcons[meta.data.slug];
            const category = meta.data.category?.[displayLang];
            const isCompleted = meta.data.status === 'completed';
            const RECENT_MS = 30 * 24 * 60 * 60 * 1000;
            const isRecentlyUpdated = !isCompleted && !!latestDate
              && (Date.now() - latestDate.valueOf() < RECENT_MS);
            const latestLabel = latestDate
              ? `${displayLang === 'ko' ? '최신' : 'Latest'} ${latestDate.getFullYear()}-${String(latestDate.getMonth() + 1).padStart(2, '0')}`
              : '';
            return (
              <li>
                <details class="series-item" id={`series-${meta.data.slug}`}>
                  <summary>
                    <span class="series-initial" aria-hidden="true">
                      {iconName ? (
                        <img src={`/logos/series/${iconName}.svg`} alt="" width="20" height="20" />
                      ) : (
                        initial
                      )}
                    </span>
                    <div class="series-body">
                      <div class="series-head">
                        <span class="series-name">{title}</span>
                        <span class="series-count">
                          {count}{displayLang === 'ko' ? '편' : ` piece${count === 1 ? '' : 's'}`}
                        </span>
                      </div>
                      <div class="series-tags">
                        {category && <span class="series-tag series-tag-category">{category}</span>}
                        {isCompleted && <span class="series-tag series-tag-status is-completed">Completed</span>}
                        {isRecentlyUpdated && <span class="series-tag series-tag-status is-updated">Updated</span>}
                        {latestLabel && <span class="series-latest">{latestLabel}</span>}
                      </div>
                      {description && <p class="series-description">{description}</p>}
                    </div>
                    <span class="chevron" aria-hidden="true">＋</span>
                  </summary>
                  <div class="expanded">
                    <ul class="entries">
                      {entries.map((entry) => {
                        const href = entry.data.externalUrl ?? '#';
                        const isExternal = !!entry.data.externalUrl;
                        const src = sourceLabel(entry.data.source);
                        return (
                          <li class="entry">
                            <a
                              href={href}
                              target={isExternal ? '_blank' : undefined}
                              rel={isExternal ? 'noopener noreferrer' : undefined}
                            >
                              <time datetime={entry.data.date.toISOString()}>{dateLabel(entry.data.date)}</time>
                              <span class="entry-title">{entry.data.title}</span>
                              {src && <span class="entry-source">{src}</span>}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                </details>
              </li>
            );
          })}

          {uncategorized.length > 0 && (
            <li>
              <details class="series-item">
                <summary>
                  <span class="series-initial" aria-hidden="true">•</span>
                  <div class="series-body">
                    <div class="series-head">
                      <span class="series-name">
                        {displayLang === 'ko' ? '시리즈에 속하지 않은 글' : 'Uncategorized'}
                      </span>
                      <span class="series-count">
                        {uncategorized.length}{displayLang === 'ko' ? '편' : ` piece${uncategorized.length === 1 ? '' : 's'}`}
                      </span>
                    </div>
                  </div>
                  <span class="chevron" aria-hidden="true">＋</span>
                </summary>
                <div class="expanded">
                  <ul class="entries">
                    {uncategorized.map((entry) => {
                      const href = entry.data.externalUrl ?? '#';
                      const isExternal = !!entry.data.externalUrl;
                      const src = sourceLabel(entry.data.source);
                      return (
                        <li class="entry">
                          <a
                            href={href}
                            target={isExternal ? '_blank' : undefined}
                            rel={isExternal ? 'noopener noreferrer' : undefined}
                          >
                            <time datetime={entry.data.date.toISOString()}>{dateLabel(entry.data.date)}</time>
                            <span class="entry-title">{entry.data.title}</span>
                            {src && <span class="entry-source">{src}</span>}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              </details>
            </li>
          )}
        </ol>
      </div>
    </section>

    <section class="cta-section" id="contact" aria-labelledby="cta-heading">
      <div class="cta-inner">
        <p class="contact-tags">Advising · speaking · coffee chats · a conversation we could share</p>
        <h2 class="cta-heading" id="cta-heading">If there's a problem you're solving or a story to connect,<br />I'd love to hear from you.</h2>
        <div class="cta-buttons">
          <a href="/contact" class="btn">Say Hello</a>
          <a href="https://linkedin.com/in/chaesang" target="_blank" rel="noopener noreferrer" class="btn btn-outline">LinkedIn</a>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .list-hero { padding: var(--space-8) 0 var(--space-4); }
  .list-hero h1 { font-size: 1.875rem; margin: 0 0 var(--space-2); letter-spacing: -0.025em; line-height: 1.2; }
  .list-lead { font-size: 1rem; color: var(--color-muted); max-width: 560px; margin: 0; line-height: 1.7; }
  .notice {
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin-top: var(--space-3);
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface-2);
    border-radius: 4px;
    display: inline-block;
  }
  .list-body { padding: var(--space-4) 0 var(--space-11); }

  .series-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .series-list li {
    border-bottom: 1px solid var(--color-border);
  }
  .series-list li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .series-item summary {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    padding: var(--space-6) 0;
    cursor: pointer;
    list-style: none;
  }
  .series-item summary::-webkit-details-marker { display: none; }
  .series-item summary:hover .series-name { color: var(--color-accent); }
  .series-item summary:hover .chevron { color: var(--color-accent); }

  .series-initial {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-muted);
    flex-shrink: 0;
    transition: color var(--transition-base), border-color var(--transition-base);
  }
  .series-initial img {
    width: 20px;
    height: 20px;
    opacity: 0.7;
    transition: opacity var(--transition-base);
  }
  .series-item[open] .series-initial {
    color: var(--color-text);
    border-color: var(--color-subtle);
  }
  .series-item[open] .series-initial img {
    opacity: 1;
  }

  .series-body { flex: 1; min-width: 0; }
  .series-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 4px;
  }
  .series-name {
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-text);
    transition: color var(--transition-base);
  }
  .series-count {
    font-size: 0.8125rem;
    color: var(--color-subtle);
    flex-shrink: 0;
  }
  .series-description {
    font-size: 0.9375rem;
    color: var(--color-muted);
    margin: 6px 0 0;
    line-height: 1.7;
  }

  .series-tags {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 6px;
  }
  .series-tag {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1.4;
  }
  .series-tag-category {
    color: var(--color-muted);
    background: var(--color-surface-2);
  }
  .series-tag-status.is-updated {
    color: var(--color-accent);
    background: var(--color-accent-soft);
  }
  .series-tag-status.is-completed {
    color: var(--color-subtle);
    background: var(--color-surface-2);
  }
  .series-latest {
    font-size: 0.75rem;
    color: var(--color-subtle);
    margin-left: 2px;
    font-variant-numeric: tabular-nums;
  }

  .chevron {
    font-size: 1.25rem;
    color: var(--color-subtle);
    flex-shrink: 0;
    line-height: 1;
    padding-top: 10px;
    transition: transform 0.25s ease, color 0.25s ease;
  }
  .series-item[open] .chevron {
    transform: rotate(45deg);
    color: var(--color-accent);
  }

  .expanded {
    padding: 0 0 var(--space-6) calc(40px + var(--space-5));
  }

  .entries {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .entry {
    border-top: 1px solid var(--color-border);
  }
  .entry:first-child { border-top: none; }
  .entry a {
    display: grid;
    grid-template-columns: 96px 1fr auto;
    gap: var(--space-4);
    align-items: baseline;
    padding: var(--space-3) 0;
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-base);
  }
  .entry a:hover { color: var(--color-accent); }
  .entry time {
    font-size: 0.8125rem;
    color: var(--color-subtle);
    font-variant-numeric: tabular-nums;
  }
  .entry-title {
    font-size: 1.0625rem;
    font-weight: 500;
    line-height: 1.45;
    min-width: 0;
  }
  .entry-source {
    font-size: 0.75rem;
    color: var(--color-subtle);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .entries a[target="_blank"]::after { content: none; }

  @media (max-width: 639px) {
    .list-hero { padding: var(--space-6) 0 var(--space-3); }
    .list-body { padding: var(--space-3) 0 var(--space-9); }
    .series-item summary { padding: var(--space-5) 0; gap: var(--space-4); }
    .series-initial { width: 36px; height: 36px; font-size: 0.8125rem; }
    .expanded { padding: 0 0 var(--space-5) calc(36px + var(--space-4)); }
    .entry a {
      grid-template-columns: 80px 1fr;
      grid-template-rows: auto auto;
      gap: 2px var(--space-3);
      padding: var(--space-3) 0;
    }
    .entry-source {
      grid-column: 2;
      grid-row: 2;
    }
  }
</style>
