---
import { getCollection } from 'astro:content';
import Base from '~/layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('projects', (e) => !e.data.draft && e.data.lang === 'ko');
  return entries.map((entry) => {
    const slug = entry.slug.split('/').pop()!;
    return { params: { slug }, props: { entry } };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const fmt = (d: Date) => `${d.getFullYear()}`;
const period = entry.data.period.end
  ? `${fmt(entry.data.period.start)} – ${fmt(entry.data.period.end)}`
  : `${fmt(entry.data.period.start)} –`;
---
<Base
  title={`${entry.data.title} — 함께 했던 프로젝트들 — 정채상`}
  description={entry.data.summary}
  lang="ko"
  path={`/ko/projects/${entry.slug.split('/').pop()}`}
  ogType="article"
  altLangPath={`/projects/${entry.slug.split('/').pop()}`}
>
  <main>
    <article class="project-detail">
      <div class="detail-inner">
        <nav class="breadcrumb"><a href="/ko/projects">← 함께 했던 프로젝트들</a></nav>
        <header class="detail-header">
          <div class="meta">
            {entry.data.client && <span>{entry.data.client}</span>}
            <span>{period}</span>
          </div>
          <h1>{entry.data.title}</h1>
          {entry.data.role && <p class="role">{entry.data.role}</p>}
          <p class="summary">{entry.data.summary}</p>
        </header>
        {entry.data.outcomes.length > 0 && (
          <section class="outcomes">
            <h3>결과</h3>
            <ul>
              {entry.data.outcomes.map((o) => <li>{o}</li>)}
            </ul>
          </section>
        )}
        <div class="prose"><Content /></div>
        {entry.data.links && entry.data.links.length > 0 && (
          <aside class="links">
            <h3>관련 링크</h3>
            <ul>
              {entry.data.links.map((l) => (
                <li><a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a></li>
              ))}
            </ul>
          </aside>
        )}
      </div>
    </article>
  </main>
</Base>

<style>
  .project-detail { padding: 48px 0 80px; }
  .detail-inner { max-width: 640px; margin: 0 auto; padding: 0 24px; }
  .breadcrumb { margin-bottom: 24px; font-size: 0.875rem; }
  .breadcrumb a { color: var(--color-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); }
  .detail-header { margin-bottom: 32px; border-bottom: 1px solid var(--color-border); padding-bottom: 24px; }
  .meta { display: flex; gap: 12px; font-size: 0.8125rem; color: var(--color-muted); margin-bottom: 12px; }
  .detail-header h1 { font-size: 1.75rem; margin: 0 0 6px; line-height: 1.3; }
  .role { font-size: 1rem; color: var(--color-muted); margin: 0 0 12px; }
  .summary { font-size: 1rem; line-height: 1.7; color: var(--color-text); margin: 0; }
  .outcomes { margin: 32px 0; }
  .outcomes h3 { font-size: 1rem; font-weight: 600; margin: 0 0 10px; }
  .outcomes ul { padding-left: 24px; margin: 0; }
  .outcomes li { margin-bottom: 6px; line-height: 1.7; }
  .prose { font-size: 1rem; line-height: 1.9; color: var(--color-text); }
  .prose :global(p) { margin: 0 0 16px; }
  .links { margin-top: 48px; padding: 16px 20px; background: var(--color-border); border-radius: 6px; }
  .links h3 { font-size: 0.9375rem; font-weight: 600; margin: 0 0 8px; }
  .links ul { margin: 0; padding-left: 18px; }
  .links a { color: var(--color-accent); }
</style>
