---
import Base from '~/layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('companies', (e) => !e.data.draft && e.data.lang === 'ko'))
  .sort((a, b) => b.data.period.start.valueOf() - a.data.period.start.valueOf());
---
<Base
  title="거쳐 온 자리들 — 정채상"
  description="한국과 실리콘밸리에서 지내 온 자리들을 모아 둡니다."
  lang="ko"
  path="/ko/companies"
  ogType="website"
  altLangPath="/companies"
>
  <main>
    <section class="list-hero">
      <div class="container">
        <h1>거쳐 온 자리들</h1>
        <p class="list-lead">셋톱박스 펌웨어에서 산업 AI까지, 여러 자리를 지나왔습니다.</p>
      </div>
    </section>

    <section class="list-body">
      <div class="container">
        {entries.length === 0 ? (
          <p class="empty">아직 정리된 항목이 없습니다.</p>
        ) : (
          <ol class="company-list">
            {entries.map((e) => {
              const slug = e.slug.split('/').pop()!;
              const start = e.data.period.start;
              const end = e.data.period.end;
              const fmt = (d: Date) => `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}`;
              const period = end ? `${fmt(start)} – ${fmt(end)}` : `${fmt(start)} – 현재`;
              return (
                <li>
                  <a href={`/ko/companies/${slug}`}>
                    <div class="company-head">
                      <span class="company-name">{e.data.name}</span>
                      <span class="company-period">{period}</span>
                    </div>
                    <div class="company-role">{e.data.role}</div>
                    {e.data.summary && <p class="company-summary">{e.data.summary}</p>}
                  </a>
                </li>
              );
            })}
          </ol>
        )}
      </div>
    </section>
  </main>
</Base>

<style>
  .list-hero { padding: 64px 0 24px; border-bottom: 1px solid var(--color-border); }
  .list-hero h1 { font-size: 2rem; margin: 0 0 10px; }
  .list-lead { font-size: 1rem; color: var(--color-muted); max-width: 640px; margin: 0; line-height: 1.7; }
  .list-body { padding: 32px 0 80px; }
  .empty { color: var(--color-muted); padding: 32px 0; text-align: center; }
  .company-list { list-style: none; padding: 0; margin: 0; }
  .company-list li { border-top: 1px solid var(--color-border); }
  .company-list li:last-child { border-bottom: 1px solid var(--color-border); }
  .company-list a { display: block; padding: 20px 0; color: inherit; text-decoration: none; }
  .company-list a:hover .company-name { color: var(--color-accent); }
  .company-head { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; margin-bottom: 4px; }
  .company-name { font-size: 1.125rem; font-weight: 600; }
  .company-period { font-size: 0.8125rem; color: var(--color-muted); flex-shrink: 0; }
  .company-role { font-size: 0.9375rem; color: var(--color-muted); margin-bottom: 6px; }
  .company-summary { font-size: 0.9375rem; color: var(--color-text); margin: 0; line-height: 1.6; }
</style>
