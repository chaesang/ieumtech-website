---
import Base from '~/layouts/Base.astro';
import { getCollection } from 'astro:content';

const rawEntries = (await getCollection('companies', (e) => !e.data.draft && e.data.lang === 'ko'))
  .sort((a, b) => b.data.period.start.valueOf() - a.data.period.start.valueOf());

const entries = await Promise.all(
  rawEntries.map(async (e) => {
    const { Content } = await e.render();
    return { entry: e, Content };
  })
);

const fmt = (d: Date) => `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}`;

const companyLogos: Record<string, string> = {
  'google': 'google.svg',
  'samsung-semiconductor': 'samsung-semiconductor.svg',
};
---
<Base
  title="거쳐 온 자리들 — 정채상"
  description="한국과 실리콘밸리에서 지내 온 자리들을 한 페이지에 모아 둡니다. 각 자리를 클릭하면 자세한 이력이 펼쳐집니다."
  lang="ko"
  path="/ko/companies"
  ogType="website"
  altLangPath="/companies"
>
  <main>
    <section class="list-hero">
      <div class="container">
        <h1>거쳐 온 자리들</h1>
        <p class="list-lead">기술과 팀을 통해 이어온 여정입니다. 셋톱박스 펌웨어에서 산업 AI까지, 30년간 여러 자리에서 배우고 기여하며 지나왔습니다.</p>
      </div>
    </section>

    <section class="list-body">
      <div class="container">
        {entries.length === 0 ? (
          <p class="empty">아직 정리된 항목이 없습니다.</p>
        ) : (
          <ol class="company-list">
            {entries.map(({ entry, Content }) => {
              const start = entry.data.period.start;
              const end = entry.data.period.end;
              const period = end ? `${fmt(start)} – ${fmt(end)}` : `${fmt(start)} – 현재`;
              const initial = entry.data.name.charAt(0).toUpperCase();
              const slug = entry.slug.split('/').pop()!;
              const logoFile = companyLogos[slug];
              return (
                <li>
                  <details class="company-item" id={`co-${slug}`}>
                    <summary>
                      <span class="company-initial" aria-hidden="true">
                        {logoFile ? (
                          <img src={`/logos/companies/${logoFile}`} alt="" width="20" height="20" />
                        ) : (
                          initial
                        )}
                      </span>
                      <div class="company-body">
                        <div class="company-head">
                          <span class="company-name">{entry.data.name}</span>
                          <span class="company-period">{period}</span>
                        </div>
                        <div class="company-role">{entry.data.role}</div>
                        {entry.data.summary && <p class="company-summary">{entry.data.summary}</p>}
                      </div>
                      <span class="chevron" aria-hidden="true">＋</span>
                    </summary>
                    <div class="expanded">
                      <div class="prose">
                        <Content />
                      </div>
                      {entry.data.links && entry.data.links.length > 0 && (
                        <aside class="links">
                          <h3>관련 링크</h3>
                          <ul>
                            {entry.data.links.map((l) => (
                              <li><a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a></li>
                            ))}
                          </ul>
                        </aside>
                      )}
                    </div>
                  </details>
                </li>
              );
            })}
          </ol>
        )}
      </div>
    </section>

    <section class="cta-section" id="contact" aria-labelledby="cta-heading">
      <div class="cta-inner">
        <p class="contact-tags">자문 · 강연 · 커피챗 · 무엇이든 좋습니다</p>
        <h2 class="cta-heading" id="cta-heading">함께 고민하고 잇고 싶은 이야기가 있다면,<br />언제든 편하게 말을 건네주세요.</h2>
        <div class="cta-buttons">
          <a href="mailto:hello@ieumtech.net" class="btn">Say Hello</a>
          <a href="https://linkedin.com/in/chaesang" target="_blank" rel="noopener noreferrer" class="btn btn-outline">LinkedIn</a>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .list-hero { padding: var(--space-8) 0 var(--space-4); }
  .list-hero h1 { font-size: 1.875rem; margin: 0 0 var(--space-2); letter-spacing: -0.025em; line-height: 1.2; }
  .list-lead { font-size: 1rem; color: var(--color-muted); max-width: 560px; margin: 0; line-height: 1.7; }
  .list-body { padding: var(--space-4) 0 var(--space-11); }
  .empty { color: var(--color-muted); padding: var(--space-9) 0; text-align: center; }

  /* Accordion list */
  .company-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .company-list li {
    border-bottom: 1px solid var(--color-border);
  }
  .company-list li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .company-item {
    /* no extra borders; lines come from <li> */
  }
  .company-item summary {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    padding: var(--space-6) 0;
    cursor: pointer;
    list-style: none;
    transition: background var(--transition-base);
  }
  .company-item summary::-webkit-details-marker { display: none; }
  .company-item summary:hover .company-name { color: var(--color-accent); }
  .company-item summary:hover .chevron { color: var(--color-accent); }

  .company-initial {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-muted);
    flex-shrink: 0;
    transition: color var(--transition-base), border-color var(--transition-base);
  }
  .company-initial img {
    width: 20px;
    height: 20px;
    opacity: 0.7;
    transition: opacity var(--transition-base);
  }
  .company-item[open] .company-initial {
    color: var(--color-text);
    border-color: var(--color-subtle);
  }
  .company-item[open] .company-initial img {
    opacity: 1;
  }

  .company-body { flex: 1; min-width: 0; }
  .company-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 4px;
  }
  .company-name {
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-text);
    transition: color var(--transition-base);
  }
  .company-period {
    font-size: 0.8125rem;
    color: var(--color-subtle);
    flex-shrink: 0;
  }
  .company-role {
    font-size: 0.9375rem;
    color: var(--color-muted);
    margin-bottom: var(--space-2);
  }
  .company-summary {
    font-size: 0.9375rem;
    color: var(--color-text);
    margin: 0;
    line-height: 1.7;
  }

  .chevron {
    font-size: 1.25rem;
    color: var(--color-subtle);
    flex-shrink: 0;
    line-height: 1;
    padding-top: 10px;
    transition: transform 0.25s ease, color 0.25s ease;
  }
  .company-item[open] .chevron {
    transform: rotate(45deg);
    color: var(--color-accent);
  }

  /* Expanded content */
  .expanded {
    padding: 0 0 var(--space-7) calc(40px + var(--space-5));
  }
  .prose {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-text);
  }
  .prose :global(h2) {
    font-size: 1rem;
    font-weight: 600;
    margin: var(--space-5) 0 var(--space-2);
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .prose :global(h2:first-child) { margin-top: 0; }
  .prose :global(h3) {
    font-size: 0.9375rem;
    font-weight: 600;
    margin: var(--space-4) 0 6px;
  }
  .prose :global(p) { margin: 0 0 var(--space-3); }
  .prose :global(ul) { padding-left: var(--space-5); margin: 0 0 var(--space-3); }
  .prose :global(li) { margin-bottom: 6px; }
  .prose :global(strong) { font-weight: 600; }

  .links {
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px dashed var(--color-border);
  }
  .links h3 {
    font-size: 0.75rem;
    font-weight: 600;
    margin: 0 0 var(--space-2);
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .links ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.875rem;
  }
  .links a { color: var(--color-accent); }

  @media (max-width: 639px) {
    .list-hero { padding: var(--space-6) 0 var(--space-3); }
    .list-body { padding: var(--space-3) 0 var(--space-9); }
    .company-item summary { padding: var(--space-5) 0; gap: var(--space-4); }
    .company-initial { width: 36px; height: 36px; font-size: 0.8125rem; }
    .expanded { padding: 0 0 var(--space-6) calc(36px + var(--space-4)); }
  }
</style>
