---
import Base from '~/layouts/Base.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: '정채상',
  alternateName: 'Chaesang Jung',
  url: 'https://ieumtech.net/ko/',
  sameAs: 'https://linkedin.com/in/chaesang',
  description: '30년간, 한국과 실리콘밸리 사이, 사람과 기술 사이를 이어 왔습니다.',
};
---
<Base
  title="정채상 · Chaesang Jung — 이음"
  description="한국과 실리콘밸리를 오가며 IT 현장에서 지내왔습니다. 지나온 자리들과 쌓인 배움을 여기에 모아 둡니다."
  ogTitle="정채상 · Chaesang Jung"
  ogDescription="한국과 실리콘밸리를 오가며 IT 현장에서 지내온 시간을 모아 두는 자리."
  lang="ko"
  path="/ko/"
  ogType="profile"
  jsonLd={jsonLd}
  altLangPath="/"
>
  <style slot="head" is:inline>
    /* Hero */
    .hero {
      background: var(--color-surface);
      padding: var(--space-8) 0 var(--space-6);
      text-align: left;
    }
    .hero-inner {
      max-width: var(--container-max);
      margin: 0 auto;
      padding: 0 var(--container-padding);
    }
    .hero-head {
      display: flex;
      align-items: flex-start;
      gap: var(--space-5);
      margin-bottom: var(--space-4);
    }
    .hero-avatar img {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      object-fit: cover;
    }
    .hero-text {
      flex: 1;
      min-width: 0;
    }
    .hero-name {
      font-size: 1.875rem;
      font-weight: 600;
      letter-spacing: -0.025em;
      line-height: 1.15;
      margin: 0 0 2px;
      color: var(--color-text);
    }
    .hero-name-en {
      font-size: 0.875rem;
      color: var(--color-muted);
      margin: 0 0 var(--space-3);
    }
    .hero-bio {
      font-size: 1rem;
      line-height: 1.7;
      color: var(--color-text);
      margin: 0 0 var(--space-4);
    }
    .breadth {
      font-size: 0.8125rem;
      color: var(--color-muted);
      line-height: 1.7;
      margin: 0 0 var(--space-4);
    }
    .breadth-row {
      display: flex;
      gap: var(--space-4);
    }
    .breadth-label {
      color: var(--color-subtle);
      min-width: 56px;
      flex-shrink: 0;
    }
    .breadth-values {
      flex: 1;
    }
    .hero-now {
      font-size: 0.9375rem;
      line-height: 1.6;
      color: var(--color-muted);
      margin: 0;
    }

    /* Anchor Grid */
    .anchor-grid-section {
      padding: var(--space-8) 0 var(--space-8);
    }
    .anchor-grid-inner {
      max-width: var(--container-max);
      margin: 0 auto;
      padding: 0 var(--container-padding);
    }
    .anchor-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4);
    }
    .anchor-card {
      display: block;
      padding: var(--space-6);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      text-decoration: none;
      color: inherit;
      transition: border-color var(--transition-fast), background var(--transition-fast);
    }
    .anchor-card:hover {
      border-color: var(--color-accent);
      background: var(--color-surface);
    }
    .anchor-card:hover .anchor-title {
      color: var(--color-accent);
    }
    .anchor-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-text);
      margin-bottom: 4px;
      transition: color var(--transition-fast);
    }
    .anchor-hint {
      font-size: 0.875rem;
      color: var(--color-muted);
      line-height: 1.6;
    }

    /* Soft Contact */
    .cta-section {
      padding: var(--space-9) var(--container-padding);
    }
    .contact-tags {
      font-size: 0.875rem;
      color: var(--color-muted);
      margin-bottom: var(--space-4);
      letter-spacing: 0.02em;
    }

    @media (max-width: 639px) {
      .anchor-grid {
        grid-template-columns: 1fr;
      }
      .breadth-row {
        flex-direction: column;
        gap: 2px;
      }
      .breadth-label {
        min-width: 0;
      }
    }
  </style>

  <section class="hero" id="home">
    <div class="hero-inner">
      <div class="hero-head">
        <div class="hero-avatar">
          <img src="/profile.jpg" alt="정채상" width="80" height="80" loading="lazy" />
        </div>
        <div class="hero-text">
          <h1 class="hero-name">정채상</h1>
          <p class="hero-name-en">Chaesang Jung</p>
        </div>
      </div>
      <p class="hero-bio">30년간, 한국과 실리콘밸리 사이, 사람과 기술 사이를 이어 왔습니다.</p>
      <div class="breadth" aria-label="경력 개요">
        <div class="breadth-row">
          <span class="breadth-label">역할</span>
          <span class="breadth-values">소프트웨어 엔지니어 / 테크 리드 / 피플 매니저 / 프로덕트 매니저 / 기술 자문 / 리더십 / 겸임교수</span>
        </div>
        <div class="breadth-row">
          <span class="breadth-label">도메인</span>
          <span class="breadth-values">임베디드 / 스마트폰 / 컨슈머 서비스 / 기술 인프라 / 빅데이터 / AI</span>
        </div>
      </div>
      <p class="hero-now">여전히 배우기를 즐기고, 나누기를 좋아하며, 여러 자리에서 잇는 역할을 합니다.</p>
    </div>
  </section>

  <main>
    <section class="anchor-grid-section" aria-label="주요 섹션 바로가기">
      <div class="anchor-grid-inner">
        <div class="anchor-grid">
          <a href="/ko/companies" class="anchor-card">
            <div class="anchor-title">거쳐 온 자리들</div>
            <div class="anchor-hint">여러 갈래의 자취</div>
          </a>
          <a href="/ko/writing" class="anchor-card">
            <div class="anchor-title">글</div>
            <div class="anchor-hint">에세이 · 기고</div>
          </a>
          <a href="/ko/talks" class="anchor-card">
            <div class="anchor-title">강연과 강의</div>
            <div class="anchor-hint">강연 · 강의 · 워크숍</div>
          </a>
          <a href="/ko/about" class="anchor-card">
            <div class="anchor-title">조금 더 자세히</div>
          </a>
        </div>
      </div>
    </section>

    <section class="cta-section" id="contact" aria-labelledby="cta-heading">
      <div class="cta-inner">
        <p class="contact-tags">자문 · 강연 · 강의 · 같이 나눌 이야기</p>
        <h2 class="cta-heading" id="cta-heading">함께 할 이야기가 있다면, 편하게 연락 주세요.</h2>
        <div class="cta-buttons">
          <a href="mailto:hello@ieumtech.net" class="btn">이메일</a>
          <a href="https://linkedin.com/in/chaesang" target="_blank" rel="noopener noreferrer" class="btn btn-outline">LinkedIn</a>
        </div>
      </div>
    </section>
  </main>
</Base>
