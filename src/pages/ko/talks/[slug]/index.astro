---
import { getCollection } from 'astro:content';
import Base from '~/layouts/Base.astro';

export async function getStaticPaths() {
  const entries = (await getCollection('talks', (e) => !e.data.draft && e.data.lang === 'ko'))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return entries.map((entry, idx) => {
    const slug = entry.slug.split('/').pop()!;
    const prev = entries[idx - 1] ?? null;
    const next = entries[idx + 1] ?? null;
    return { params: { slug }, props: { entry, prev, next } };
  });
}

const { entry, prev, next } = Astro.props;
const { Content } = await entry.render();
const dateLabel = entry.data.date.toLocaleDateString('ko-KR', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const formatLabel: Record<string, string> = {
  keynote: '키노트', panel: '패널', workshop: '워크숍',
  interview: '인터뷰', podcast: '팟캐스트', lecture: '강의',
};
---
<Base
  title={`${entry.data.title} — 남긴 말과 글들 — 정채상`}
  description={`${entry.data.venue} · ${entry.data.event}`}
  lang="ko"
  path={`/ko/talks/${entry.slug.split('/').pop()}`}
  ogType="article"
  altLangPath={`/talks/${entry.slug.split('/').pop()}`}
>
  <main>
    <article class="talk-detail">
      <div class="detail-inner">
        <nav class="breadcrumb"><a href="/ko/talks">← 남긴 말과 글들</a></nav>
        <header class="detail-header">
          <div class="meta">
            <span class="format" data-format={entry.data.format}>{formatLabel[entry.data.format] ?? entry.data.format}</span>
            <time>{dateLabel}</time>
          </div>
          <h1>{entry.data.title}</h1>
          <p class="venue">{entry.data.venue} · {entry.data.event}</p>
        </header>
        <div class="prose"><Content /></div>
        {entry.data.links && entry.data.links.length > 0 && (
          <aside class="links">
            <h3>관련 링크</h3>
            <ul>
              {entry.data.links.map((l) => (
                <li><a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a></li>
              ))}
            </ul>
          </aside>
        )}
        {(prev || next) && (
          <nav class="adj-nav" aria-label="이전·다음 말과 글">
            <a
              class={`adj-nav-item ${prev ? '' : 'disabled'}`}
              href={prev ? `/ko/talks/${prev.slug.split('/').pop()}` : undefined}
              aria-disabled={prev ? undefined : 'true'}
            >
              <span class="adj-nav-dir">← 최근</span>
              {prev && <span class="adj-nav-name">{prev.data.title}</span>}
            </a>
            <a
              class={`adj-nav-item ${next ? '' : 'disabled'}`}
              href={next ? `/ko/talks/${next.slug.split('/').pop()}` : undefined}
              aria-disabled={next ? undefined : 'true'}
            >
              <span class="adj-nav-dir">이전 →</span>
              {next && <span class="adj-nav-name">{next.data.title}</span>}
            </a>
          </nav>
        )}
      </div>
    </article>
  </main>
</Base>

<style>
  .talk-detail { padding: 32px 0 56px; }
  .detail-inner { max-width: 640px; margin: 0 auto; padding: 0 24px; }
  .breadcrumb { margin-bottom: 24px; font-size: 0.875rem; }
  .breadcrumb a { color: var(--color-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); }
  .detail-header { margin-bottom: 32px; border-bottom: 1px solid var(--color-border); padding-bottom: 24px; }
  .meta { display: flex; gap: 12px; align-items: center; font-size: 0.8125rem; color: var(--color-muted); margin-bottom: 12px; }
  .detail-header h1 { font-size: 1.875rem; margin: 0 0 8px; line-height: 1.3; letter-spacing: -0.02em; }
  .venue { font-size: 0.9375rem; color: var(--color-muted); margin: 0; }
  .prose { font-size: 1rem; line-height: 1.75; color: var(--color-text); }
  .prose :global(p) { margin: 0 0 16px; }
  .links { margin-top: 32px; padding: 16px 0; border-top: 1px solid var(--color-border); }
  .links h3 { font-size: 0.875rem; font-weight: 600; margin: 0 0 8px; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.06em; }
  .links ul { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 4px; }
  .links a { color: var(--color-accent); word-break: break-all; }

  .adj-nav { margin-top: 48px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .adj-nav-item { display: flex; flex-direction: column; gap: 6px; padding: 16px; background: #fff; border: 1px solid var(--color-border); border-radius: 8px; color: var(--color-text); text-decoration: none; transition: border-color 0.15s; }
  .adj-nav-item:last-child { text-align: right; }
  .adj-nav-item:hover:not(.disabled) { border-color: var(--color-accent); }
  .adj-nav-item:hover:not(.disabled) .adj-nav-name { color: var(--color-accent); }
  .adj-nav-item.disabled { opacity: 0.4; pointer-events: none; cursor: default; }
  .adj-nav-dir { font-size: 0.75rem; color: var(--color-muted); letter-spacing: 0.02em; }
  .adj-nav-name { font-size: 0.9375rem; font-weight: 600; line-height: 1.4; }
  @media (max-width: 480px) { .adj-nav { grid-template-columns: 1fr; } .adj-nav-item:last-child { text-align: left; } }
</style>
