---
import Base from '~/layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('talks', (e) => !e.data.draft && e.data.lang === 'ko'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatLabel: Record<string, string> = {
  keynote: '키노트',
  panel: '패널',
  workshop: '워크숍',
  interview: '인터뷰',
  podcast: '팟캐스트',
  lecture: '강의',
};

const dateLabel = (d: Date) =>
  d.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit' });
---
<Base
  title="강연과 강의 — 정채상"
  description="강단과 지면에서 남긴 이야기들. 강연, 강의, 인터뷰를 모아 둡니다."
  lang="ko"
  path="/ko/talks"
  ogType="website"
  altLangPath="/talks"
>
  <main>
    <section class="list-hero">
      <div class="container">
        <h1>강연과 강의</h1>
        <p class="list-lead">강단과 지면을 통해 나누었던 기록들입니다. 현장의 배움이 다른 이들에게도 닿기를 바랍니다.</p>
      </div>
    </section>

    <section class="list-body">
      <div class="container">
        {entries.length === 0 ? (
          <p class="empty">아직 정리된 항목이 없습니다.</p>
        ) : (
          <ol class="talk-list">
            {entries.map((entry) => {
              const firstLink = entry.data.links?.[0];
              const href = firstLink?.url;
              const slug = entry.slug.split('/').pop()!;
              return (
                <li id={`talk-${slug}`}>
                  <div class="talk-row">
                    <time datetime={entry.data.date.toISOString()} class="talk-date">{dateLabel(entry.data.date)}</time>
                    <div class="talk-body">
                      <div class="talk-title">
                        {href ? (
                          <a href={href} target="_blank" rel="noopener noreferrer">{entry.data.title}</a>
                        ) : (
                          entry.data.title
                        )}
                      </div>
                      <div class="talk-meta">
                        <span class="talk-venue">{entry.data.venue} · {entry.data.event}</span>
                      </div>
                      {entry.data.links && entry.data.links.length > 1 && (
                        <ul class="talk-links">
                          {entry.data.links.slice(1).map((l) => (
                            <li><a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a></li>
                          ))}
                        </ul>
                      )}
                    </div>
                    <span class="talk-format" data-format={entry.data.format}>
                      {formatLabel[entry.data.format] ?? entry.data.format}
                    </span>
                  </div>
                </li>
              );
            })}
          </ol>
        )}
      </div>
    </section>

    <section class="cta-section" id="contact" aria-labelledby="cta-heading">
      <div class="cta-inner">
        <p class="contact-tags">자문 · 강연 · 커피챗 · 무엇이든 좋습니다</p>
        <h2 class="cta-heading" id="cta-heading">함께 고민하고 잇고 싶은 이야기가 있다면,<br />언제든 편하게 말을 건네주세요.</h2>
        <div class="cta-buttons">
          <a href="mailto:hello@ieumtech.net" class="btn">Say Hello</a>
          <a href="https://linkedin.com/in/chaesang" target="_blank" rel="noopener noreferrer" class="btn btn-outline">LinkedIn</a>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .list-hero { padding: var(--space-8) 0 var(--space-4); }
  .list-hero h1 { font-size: 1.875rem; margin: 0 0 var(--space-2); letter-spacing: -0.025em; line-height: 1.2; }
  .list-lead { font-size: 1rem; color: var(--color-muted); max-width: 560px; margin: 0; line-height: 1.7; }
  .list-body { padding: var(--space-4) 0 var(--space-11); }
  .empty { color: var(--color-muted); padding: var(--space-9) 0; text-align: center; }

  .talk-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .talk-list li {
    border-bottom: 1px solid var(--color-border);
  }
  .talk-list li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .talk-row {
    display: grid;
    grid-template-columns: 88px 1fr auto;
    gap: var(--space-4);
    align-items: baseline;
    padding: var(--space-5) 0;
  }
  .talk-date {
    font-size: 0.8125rem;
    color: var(--color-subtle);
    font-variant-numeric: tabular-nums;
    padding-top: 2px;
  }
  .talk-body {
    min-width: 0;
  }
  .talk-title {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-text);
    line-height: 1.4;
    margin-bottom: 4px;
  }
  .talk-title a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-base);
  }
  .talk-title a:hover {
    color: var(--color-accent);
  }
  .talk-meta {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
  }
  .talk-links {
    list-style: none;
    padding: 0;
    margin: var(--space-2) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-size: 0.8125rem;
  }
  .talk-links a { color: var(--color-muted); }
  .talk-links a:hover { color: var(--color-accent); }

  .talk-format {
    font-size: 0.75rem;
    color: var(--color-subtle);
    letter-spacing: 0.04em;
    padding-top: 2px;
  }

  /* No ↗ suffix on main title link (already implies clickable) */
  .talk-title a[target="_blank"]::after { content: none; }

  @media (max-width: 639px) {
    .list-hero { padding: var(--space-6) 0 var(--space-3); }
    .list-body { padding: var(--space-3) 0 var(--space-9); }
    .talk-row {
      grid-template-columns: 72px 1fr;
      grid-template-rows: auto auto;
      gap: 2px var(--space-3);
      padding: var(--space-4) 0;
    }
    .talk-format {
      grid-column: 2;
      grid-row: 2;
      padding-top: 4px;
    }
  }
</style>
