---
import Base from '~/layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('talks', (e) => !e.data.draft && e.data.lang === 'ko'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatLabel: Record<string, string> = {
  keynote: '키노트', panel: '패널', workshop: '워크숍',
  interview: '인터뷰', podcast: '팟캐스트', lecture: '강의',
};
---
<Base
  title="남긴 말들 — 정채상"
  description="강연, 인터뷰, 팟캐스트, 강의 등에 남긴 말들을 모아 둡니다."
  lang="ko"
  path="/ko/talks"
  ogType="website"
  altLangPath="/talks"
>
  <main>
    <section class="list-hero">
      <div class="container">
        <h1>남긴 말들</h1>
        <p class="list-lead">강연, 인터뷰, 팟캐스트, 강의. 말로 남긴 것들을 모아 둡니다.</p>
      </div>
    </section>
    <section class="list-body">
      <div class="container">
        {entries.length === 0 ? (
          <p class="empty">아직 정리된 항목이 없습니다.</p>
        ) : (
          <ol class="talk-list">
            {entries.map((e) => {
              const slug = e.slug.split('/').pop()!;
              const d = e.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'short' });
              return (
                <li>
                  <a href={`/ko/talks/${slug}`}>
                    <div class="talk-head">
                      <span class="talk-format">{formatLabel[e.data.format] ?? e.data.format}</span>
                      <span class="talk-date">{d}</span>
                    </div>
                    <div class="talk-title">{e.data.title}</div>
                    <div class="talk-venue">{e.data.venue} · {e.data.event}</div>
                  </a>
                </li>
              );
            })}
          </ol>
        )}
      </div>
    </section>
  </main>
</Base>

<style>
  .list-hero { padding: 64px 0 24px; border-bottom: 1px solid var(--color-border); }
  .list-hero h1 { font-size: 2rem; margin: 0 0 10px; }
  .list-lead { font-size: 1rem; color: var(--color-muted); max-width: 640px; margin: 0; line-height: 1.7; }
  .list-body { padding: 32px 0 80px; }
  .empty { color: var(--color-muted); padding: 32px 0; text-align: center; }
  .talk-list { list-style: none; padding: 0; margin: 0; }
  .talk-list li { border-top: 1px solid var(--color-border); }
  .talk-list li:last-child { border-bottom: 1px solid var(--color-border); }
  .talk-list a { display: block; padding: 20px 0; color: inherit; text-decoration: none; }
  .talk-list a:hover .talk-title { color: var(--color-accent); }
  .talk-head { display: flex; gap: 12px; align-items: center; font-size: 0.8125rem; color: var(--color-muted); margin-bottom: 6px; }
  .talk-format { padding: 2px 8px; border-radius: 4px; background: var(--color-border); font-weight: 500; }
  .talk-title { font-size: 1.125rem; font-weight: 600; line-height: 1.4; margin-bottom: 6px; }
  .talk-venue { font-size: 0.875rem; color: var(--color-muted); }
</style>
