---
import Base from '~/layouts/Base.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Chaesang Jung',
  url: 'https://ieumtech.net/about',
  jobTitle: 'Founder, Ieum Tech',
  sameAs: 'https://linkedin.com/in/chaesang',
  worksFor: {
    '@type': 'Organization',
    name: 'Ieum Tech LLC',
  },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'Seoul National University' },
  ],
};
---
<Base
  title="About Chaesang Jung — Ieum Tech"
  description="Full career profile of Chaesang Jung — Google, Banksalad, KAIST, and more."
  lang="en"
  path="/about"
  ogType="profile"
  jsonLd={jsonLd}
  altLangPath="/ko/about"
>
  <style slot="head" is:inline>
    .hero-label { margin-bottom: 28px; }
    .profile-headline { line-height: inherit; margin-top: 0; }
    .highlights-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .highlight-card { text-align: center; padding: 20px 12px; }
    .highlight-number { font-size: 1.75rem; font-weight: 600; color: var(--color-accent); letter-spacing: -0.025em; line-height: 1.2; }
    .highlight-label { font-size: 0.75rem; color: var(--color-muted); font-weight: 400; margin-top: 6px; line-height: 1.4; }
    @media (max-width: 480px) { .highlights-grid { grid-template-columns: repeat(2, 1fr); } }
    .simple-list { gap: 14px; }
    .simple-list-item .label { font-weight: 600; }
    .simple-list-item .detail { font-weight: 400; }
  </style>

  <main>
    <section class="about-section" id="about" style="border-top: none; padding-top: 56px;">
      <div class="about-inner">

        <div class="about-profile">
          <div class="profile-avatar"><img src="/profile.jpg" alt="Chaesang Jung" width="96" height="96" loading="lazy" /></div>
          <div>
            <h1 class="profile-name">Chaesang Jung</h1>
            <p class="profile-secondary-name">정채상</p>
            <p class="profile-headline">Behind every technology, there were people — I carry those stories forward.</p>
          </div>
        </div>

        <div class="about-summary">
          <ul>
            <li>Diverse domains — embedded, search, commerce, fintech, cloud, AI</li>
            <li>Google 13 years (US) + Banksalad / MegazoneCloud / KAIST (Korea)</li>
            <li>0 to scale — grew App Indexing from a demo to 50-person org; VPE at Banksalad (40+ engineers)</li>
            <li>Teaching & sharing — KAIST adjunct professor, online courses, mentoring</li>
          </ul>
        </div>

        <div class="about-block">
          <h2>Words from Colleagues</h2>
          <div style="display: flex; flex-direction: column; gap: 24px;">
            <blockquote style="margin: 0; padding: 0 0 0 16px; border-left: 2px solid var(--color-accent);">
              <p style="font-size: 0.9375rem; color: var(--color-text); font-style: italic; line-height: 1.7; margin-bottom: 8px;">"Chaesang well-balances his technical expertise with the depth of his product domain knowledge, which stems from his immense care for the users he serves. His care and empathy for his reports as a manager — thinking of how to help people grow in their careers."</p>
              <cite style="font-size: 0.8125rem; color: var(--color-muted); font-style: normal;">— Jennifer Lin, ex-Engineering Director, Google (managed Chaesang for 3 years)</cite>
            </blockquote>
            <blockquote style="margin: 0; padding: 0 0 0 16px; border-left: 2px solid var(--color-accent);">
              <p style="font-size: 0.9375rem; color: var(--color-text); font-style: italic; line-height: 1.7; margin-bottom: 8px;">"What sets Chaesang apart is his dedication to the learning and growth of his colleagues. His presence in the workplace provided us with a sense of psychological safety — we knew there was always someone to listen."</p>
              <cite style="font-size: 0.8125rem; color: var(--color-muted); font-style: normal;">— Ada Suhkyung Kim, UX Research & AI Product Lead</cite>
            </blockquote>
          </div>
        </div>

        <div class="about-block">
          <h2>Experience</h2>
          <div class="timeline">

            <div class="timeline-item">
              <div class="timeline-header">
                <span class="timeline-company">MegazoneCloud</span>
                <span class="timeline-period">2025.04 – 2026.03</span>
              </div>
              <span class="timeline-role">Distinguished Software Engineer</span>
              <ul class="timeline-details">
                <li>CEO Office at Korea's largest cloud MSP (~2,000 employees). Multi-cloud: AWS, GCP, Azure</li>
                <li>Reviewed ongoing projects for technical gaps and validated requirements across the organization</li>
                <li>Established SDLC guidelines and engineering management practices for "by Megazone" products</li>
              </ul>
            </div>

            <div class="timeline-item">
              <div class="timeline-header">
                <span class="timeline-company">KAIST College of Business</span>
                <span class="timeline-period">2023.08 – 2026.03</span>
              </div>
              <span class="timeline-role">Adjunct Professor</span>
              <ul class="timeline-details">
                <li>Taught "AI and Recommendation Systems" to Digital Finance MBA and Information Management students (~80 students/semester, 3 consecutive years). 3-credit, 15-16 week course</li>
                <li>Translated industry experience (Google Search, Playstore, AI) into practical coursework — recommendation engines, LLM integration, OpenAI API hands-on</li>
              </ul>
            </div>

            <div class="timeline-item">
              <div class="timeline-header">
                <span class="timeline-company">INEEJI</span>
                <span class="timeline-period">2024.03 – 2025.09</span>
              </div>
              <span class="timeline-role">CTO / Director of Research Institute</span>
              <ul class="timeline-details">
                <li>Led 20+ AI/SW engineers as part-time CTO</li>
                <li>Explainable AI (XAI) for industrial process optimization using Deep Temporal Neural Networks</li>
                <li>Industries: steel, cement, glass, petrochemical, power generation, transportation/logistics</li>
              </ul>
            </div>

            <div class="timeline-item">
              <div class="timeline-header">
                <span class="timeline-company">Aisle Street, Inc.</span>
                <span class="timeline-period">2024.01 – Present</span>
              </div>
              <span class="timeline-role">Co-Founder / Tech</span>
              <ul class="timeline-details">
                <li>Education AI startup, exemplar.ai</li>
                <li>RAG-based private chatting service for teachers and students</li>
                <li>Tech: React, AWS, Pinecone, RAG, LLM integration</li>
              </ul>
            </div>

            <div class="timeline-item">
              <div class="timeline-header">
                <span class="timeline-company">Banksalad</span>
                <span class="timeline-period">2022.01 – 2023.07</span>
              </div>
              <span class="timeline-role">VP of Engineering</span>
              <ul class="timeline-details">
                <li>Managed 40+ engineers (SWE, DS, DA, DevOps, EM) in an 80-person tech org</li>
                <li>75% cloud cost reduction in 6 months: right-sizing (~50%) + optimization (~50% of remainder). Personally designed Mydata optimization</li>
                <li>Mydata service: 258+ financial institutions across 6 categories, Go + gRPC + K8s + AWS. ~2s real-time asset updates (20x improvement)</li>
                <li>Hired ~20 engineers in 1.5 years; established experiment/project review processes with impact-based prioritization</li>
              </ul>
            </div>

            <div class="timeline-item">
              <div class="timeline-header">
                <span class="timeline-company">Samsung Semiconductor</span>
                <span class="timeline-period">2019.12 – 2020.12</span>
              </div>
              <span class="timeline-role">Principal SWE / Technical Advisor</span>
              <ul class="timeline-details">
                <li>Delivered leadership training on Google-scale service requirements from memory/storage perspective</li>
                <li>Informed storage division's product roadmap by translating application-tier workload patterns into concrete requirements</li>
              </ul>
            </div>

            <div class="timeline-item">
              <div class="timeline-header">
                <span class="timeline-company">Google</span>
                <span class="timeline-period">2007.07 – 2021.10</span>
              </div>
              <div class="timeline-nested">
                <div class="timeline-nested-item">
                  <div class="timeline-nested-header">
                    <span class="timeline-role">TLM — Core Systems & Experiences</span>
                    <span class="timeline-period">2020.12 – 2021.10</span>
                  </div>
                  <ul class="timeline-details">
                    <li>Cloud Logging team, planet-scale debug log infrastructure for Google engineers</li>
                  </ul>
                </div>
                <div class="timeline-nested-item">
                  <div class="timeline-nested-header">
                    <span class="timeline-role">Staff SWE — Google Lens</span>
                    <span class="timeline-period">2018.09 – 2019.12</span>
                  </div>
                  <ul class="timeline-details">
                    <li>Korean on-device OCR for Pixel 4</li>
                    <li>Lens search integration analysis pipeline</li>
                  </ul>
                </div>
                <div class="timeline-nested-item">
                  <div class="timeline-nested-header">
                    <span class="timeline-role">Staff SWE — Nest Store</span>
                    <span class="timeline-period">2017.12 – 2018.09</span>
                  </div>
                  <ul class="timeline-details">
                    <li>Payment service for store.nest.com (Hybris SAP, AWS+GCP)</li>
                    <li>Affirm BNPL integration, 100% solo — Google's first product with subscription sales</li>
                  </ul>
                </div>
                <div class="timeline-nested-item">
                  <div class="timeline-nested-header">
                    <span class="timeline-role">TLM / Product Owner — Play Store Korea & Japan</span>
                    <span class="timeline-period">2016.03 – 2017.12</span>
                  </div>
                  <ul class="timeline-details">
                    <li>Google's first region-specific consumer product, 8 SWEs — Korea & Japan = 70% of global Play Store revenue</li>
                    <li>Locality-aware search & recommendation, pre-registration campaigns</li>
                    <li>Prevented major game title migration to competing stores</li>
                  </ul>
                </div>
                <div class="timeline-nested-item">
                  <div class="timeline-nested-header">
                    <span class="timeline-role">Head of Engineering / Product Owner — Search App Indexing</span>
                    <span class="timeline-period">2012.09 – 2016.03</span>
                  </div>
                  <ul class="timeline-details">
                    <li>Initiated and led App Indexing from a single demo to global scale</li>
                    <li>Built 50-person org (4 teams); new paradigm: crawling native app content via Android simulator</li>
                    <li>Featured in Google earnings calls, Android K release, Google IO 2015 main session speaker</li>
                    <li>~90% of team (45 of 50 people) promoted during 3-year project</li>
                  </ul>
                </div>
                <div class="timeline-nested-item">
                  <div class="timeline-nested-header">
                    <span class="timeline-role">TLM — Search App Search</span>
                    <span class="timeline-period">2011.09 – 2012.08</span>
                  </div>
                  <ul class="timeline-details">
                    <li>Launched App discovery in Google Search, 5 SWEs</li>
                  </ul>
                </div>
                <div class="timeline-nested-item">
                  <div class="timeline-nested-header">
                    <span class="timeline-role">TLM — Search Korean Mobile</span>
                    <span class="timeline-period">2010.09 – 2011.08</span>
                  </div>
                  <ul class="timeline-details">
                    <li>First manager role, 8 SWEs, 10+ mobile features in 1 year</li>
                  </ul>
                </div>
                <div class="timeline-nested-item">
                  <div class="timeline-nested-header">
                    <span class="timeline-role">Senior SWE — Search Rich Snippets</span>
                    <span class="timeline-period">2009.09 – 2010.08</span>
                  </div>
                  <ul class="timeline-details">
                    <li>Movie vertical with Rich Snippets — contributed to schema.org standard definition</li>
                    <li>Foundation for what became Google's Knowledge Panel</li>
                  </ul>
                </div>
                <div class="timeline-nested-item">
                  <div class="timeline-nested-header">
                    <span class="timeline-role">Senior SWE — Search Korea</span>
                    <span class="timeline-period">2007.07 – 2009.08</span>
                  </div>
                  <ul class="timeline-details">
                    <li>Early Seoul office member (~10 people); google.co.kr search result page redesign</li>
                    <li>Introduced result groups architecture — precursor to Universal Search and Knowledge Panel</li>
                  </ul>
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-header">
                <span class="timeline-company">ETRI</span>
                <span class="timeline-period">2006 – 2007</span>
              </div>
              <span class="timeline-role">Software Engineer</span>
              <ul class="timeline-details">
                <li>Eclipse-based device driver source generator</li>
              </ul>
            </div>

            <div class="timeline-item">
              <div class="timeline-header">
                <span class="timeline-company">Teleca Korea</span>
                <span class="timeline-period">2004 – 2006</span>
              </div>
              <span class="timeline-role">Software Engineer</span>
              <ul class="timeline-details">
                <li>Symbian/Series 60 base-porting, Samsung Z600</li>
              </ul>
            </div>

            <div class="timeline-item">
              <div class="timeline-header">
                <span class="timeline-company">Palmpalm Technology</span>
                <span class="timeline-period">2000 – 2004</span>
              </div>
              <span class="timeline-role">Software Engineer</span>
              <ul class="timeline-details">
                <li>Linux smartphone (ALL-about), kernel & middleware — 7–8 years ahead of Android</li>
              </ul>
            </div>

            <div class="timeline-item">
              <div class="timeline-header">
                <span class="timeline-company">iCube</span>
                <span class="timeline-period">1999 – 2000</span>
              </div>
              <span class="timeline-role">Software Engineer</span>
              <ul class="timeline-details">
                <li>Set-top-box software, ECMAScript engine on RTOS (pSOS)</li>
              </ul>
            </div>

            <div class="timeline-item">
              <div class="timeline-header">
                <span class="timeline-company">e-motion</span>
                <span class="timeline-period">1996 – 1998</span>
              </div>
              <span class="timeline-role">Software Engineer (Part-time)</span>
              <ul class="timeline-details">
                <li>Developed and distributed packaged applications including CGI Builder (web-to-database integration tool)</li>
              </ul>
            </div>

          </div>
        </div>

        <div class="about-block">
          <h2 id="teaching">Teaching & Speaking</h2>

          <h3 style="margin-bottom: 10px; color: var(--color-accent); font-size: 0.9375rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; border-left: 2px solid var(--color-accent); padding-left: 8px;">Online Courses</h3>
          <div class="simple-list" style="margin-bottom: 28px;">
            <div class="simple-list-item">
              <span class="label">Inflearn</span>
              <span class="detail">— <a href="https://www.inflearn.com/course/%EC%8B%9C%EB%8B%88%EC%96%B4-%EA%B0%9C%EB%B0%9C%EC%9E%90%EB%A1%9C-%EC%84%B1%EC%9E%A5%ED%95%98%EA%B8%B0-%EA%B0%95%EC%9D%98?cid=333674" target="_blank" rel="noopener noreferrer">Growing into a Senior Developer</a></span>
            </div>
            <div class="simple-list-item">
              <span class="label">Inflearn</span>
              <span class="detail">— <a href="https://www.inflearn.com/course/%EC%8B%9C%EB%8B%88%EC%96%B4%EA%B0%9C%EB%B0%9C%EC%9E%90-%EB%A7%A4%EB%8B%88%EC%A0%80%EB%A1%9C-%EC%83%88%EB%A1%9C%EC%9A%B4%EB%8F%84%EC%A0%84-%EC%84%B1%EC%9E%A5-%EA%B0%95%EC%9D%98?cid=333777" target="_blank" rel="noopener noreferrer">From Senior Developer to Manager</a></span>
            </div>
            <div class="simple-list-item">
              <span class="label">Class101</span>
              <span class="detail">— <a href="https://class101.net/ko/pages/embootcamp-demand-2401-65a76a6250c526000e21ceec" target="_blank" rel="noopener noreferrer">Engineering Manager Leadership Guide</a></span>
            </div>
            <div class="simple-list-item">
              <span class="label">FastCampus</span>
              <span class="detail">— <a href="https://fastcampus.co.kr/dev_online_newcomputer" target="_blank" rel="noopener noreferrer">Computer Engineering for Everyone</a></span>
            </div>
            <div class="simple-list-item">
              <span class="label">HanbitN</span>
              <span class="detail">— <a href="https://www.hanbit.co.kr/product/C2734327343" target="_blank" rel="noopener noreferrer">Inspecting Google Play Store</a></span>
            </div>
          </div>

          <h3 style="margin-bottom: 10px; color: var(--color-accent); font-size: 0.9375rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; border-left: 2px solid var(--color-accent); padding-left: 8px;">University</h3>
          <div class="simple-list" style="margin-bottom: 28px;">
            <div class="simple-list-item">
              <span class="label">KAIST DFMBA</span>
              <span class="detail">— AI & Recommendation Systems · Lecture notes: <a href="https://brunch.co.kr/magazine/dfmba-recom" target="_blank" rel="noopener noreferrer">2023</a> · <a href="https://brunch.co.kr/magazine/kaist-dfmba-24" target="_blank" rel="noopener noreferrer">2024</a> · <a href="https://brunch.co.kr/magazine/kaist-dfmba-25" target="_blank" rel="noopener noreferrer">2025</a></span>
            </div>
          </div>

          <h3 style="margin-bottom: 10px; color: var(--color-accent); font-size: 0.9375rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; border-left: 2px solid var(--color-accent); padding-left: 8px;">Talks & Interviews</h3>
          <div class="simple-list" style="margin-bottom: 28px;">
            <div class="simple-list-item">
              <span class="label">OKKY</span>
              <span class="detail">— <a href="https://www.youtube.com/watch?v=pQEUqoZRKpw" target="_blank" rel="noopener noreferrer">개발조직 관리, 나만 이렇게 힘든거야?</a> (2024.01)</span>
            </div>
            <div class="simple-list-item">
              <span class="label">Talk</span>
              <span class="detail">— 코딩이 제일 쉬웠어요 — N년차 개발자의 코딩 이외의 경험들</span>
            </div>
            <div class="simple-list-item">
              <span class="label">Talk</span>
              <span class="detail">— 어느 개발자의 실리콘 밸리(구글) 생존 이야기</span>
            </div>
            <div class="simple-list-item">
              <span class="label">은종쌤의 IT 이야기들</span>
