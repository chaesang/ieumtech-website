---
import Base from '~/layouts/Base.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Chaesang Jung',
  alternateName: '정채상',
  url: 'https://ieumtech.net/about',
  jobTitle: 'Founder, Ieum Tech',
  sameAs: 'https://linkedin.com/in/chaesang',
  worksFor: { '@type': 'Organization', name: 'Ieum Tech' },
  alumniOf: [{ '@type': 'CollegeOrUniversity', name: 'Seoul National University' }],
};
---
<Base
  title="About Chaesang Jung — Ieum Tech"
  description="Where technology has passed, there have always been people — a short narrative of Chaesang Jung's path."
  lang="en"
  path="/about"
  ogType="profile"
  jsonLd={jsonLd}
  altLangPath="/ko/about"
>
  <main>
    <section class="about-hero">
      <div class="about-inner">
        <div class="hero-head">
          <div class="hero-avatar">
            <img src="/profile.jpg" alt="Chaesang Jung" width="80" height="80" loading="lazy" />
          </div>
          <div class="hero-text">
            <h1 class="hero-name">Chaesang Jung</h1>
            <p class="hero-name-en">정채상</p>
          </div>
        </div>
        <p class="hero-headline">Where technology has passed, there have always been people.</p>
      </div>
    </section>

    <section class="about-narrative">
      <div class="about-inner">
        <article class="prose">
          <h2>Start</h2>
          <p>I met computers in Seoul in the 1980s. Through the 1990s as a computer science student, curiosity led before the major did — and that current carried me from set-top box firmware to search, mobile OSes, cloud, and industrial AI.</p>

          <h2>Thirteen years at Google</h2>
          <p>In 2007 I joined Google's Seoul office as one of its earliest members. I started as an engineer and became a manager, moving between Search, App Indexing, Play Store, Lens, and Cloud Logging. Some years I spent growing a single demo into an organization; other years I spent growing people inside a finished product. Some of that worked. Some of it quietly folded.</p>

          <h2>Since then</h2>
          <p>In 2022 I worked as VP of Engineering at Banksalad. I then served as CTO at INEEJI, Adjunct Professor at KAIST College of Business, and Distinguished Software Engineer at MegazoneCloud — and co-founded Aisle Street, an education-AI startup building exemplar.ai.</p>

          <h2>Now</h2>
          <p>Building, leading, teaching, writing — and lending a hand alongside. Between Silicon Valley's speed and Korea's context, between the engineer's hands and the leader's sight, still learning, still glad to share.</p>

          <h2>Why</h2>
          <p>Where technology has passed, there have always been people. The editor I used alone, the colleagues in the organization, the classroom I stand in now — in the end, it was always about connecting people to people, and people to technology.</p>

          <p class="background-meta">Seoul National University, M.Eng. & B.Eng. in Computer Engineering · 5 U.S. patents during Google tenure</p>
        </article>
      </div>
    </section>

    <section class="about-testimonials">
      <div class="about-inner">
        <h2 class="section-label">From people I've worked with</h2>
        <div class="testimonial-stack">
          <blockquote class="testimonial">
            <p class="testimonial-text">"Chaesang well-balances his technical expertise with the depth of his product domain knowledge, which stems from his immense care for the users he serves. His care and empathy for his reports as a manager — thinking of how to help people grow in their careers."</p>
            <footer class="testimonial-attr">— Jennifer Lin, ex-Engineering Director, Google (managed Chaesang for 3 years)</footer>
          </blockquote>
          <blockquote class="testimonial">
            <p class="testimonial-text">"What sets Chaesang apart is his dedication to the learning and growth of his colleagues. His presence in the workplace provided us with a sense of psychological safety — we knew there was always someone to listen."</p>
            <footer class="testimonial-attr">— Ada Suhkyung Kim, UX Research & AI Product Lead</footer>
          </blockquote>
        </div>
      </div>
    </section>

    <section class="cta-section" id="contact" aria-labelledby="cta-heading">
      <div class="cta-inner">
        <h2 class="cta-heading" id="cta-heading">Have a story to share or a problem to solve?</h2>
        <p class="cta-sub">Half-formed thoughts and questions are always welcome.</p>
        <div class="cta-buttons">
          <a href="mailto:hello@ieumtech.net" class="btn">Say Hello</a>
          <a href="https://linkedin.com/in/chaesang" target="_blank" rel="noopener noreferrer" class="btn btn-outline">LinkedIn</a>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .about-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .about-hero {
    padding: var(--space-8) 0 var(--space-6);
    background: var(--color-surface);
  }
  .hero-head {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    margin-bottom: var(--space-5);
  }
  .hero-avatar img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
  }
  .hero-text { flex: 1; min-width: 0; }
  .hero-name {
    font-size: 1.875rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin: 0 0 2px;
    color: var(--color-text);
  }
  .hero-name-en {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0;
  }
  .hero-headline {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .about-narrative { padding: var(--space-7) 0 var(--space-9); }
  .prose {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text);
  }
  .prose h2 {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-subtle);
    margin: var(--space-7) 0 var(--space-3);
  }
  .prose h2:first-child { margin-top: 0; }
  .prose p { margin: 0; }

  .section-label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-subtle);
    margin: 0 0 var(--space-4);
  }

  .about-testimonials {
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
  }
  .testimonial-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .testimonial {
    margin: 0;
    padding: 0 0 0 var(--space-5);
    border-left: 2px solid var(--color-subtle);
  }
  .testimonial-text {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }
  .testimonial-attr {
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .background-meta {
    margin-top: var(--space-7);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: 0.8125rem;
    color: var(--color-subtle);
    line-height: 1.6;
  }

  @media (max-width: 639px) {
    .about-hero { padding: var(--space-6) 0 var(--space-5); }
    .hero-name { font-size: 1.625rem; }
    .hero-headline { font-size: 1rem; }
    .about-narrative { padding: var(--space-6) 0 var(--space-8); }
    .about-testimonials { padding: var(--space-7) 0; }
  }
</style>
