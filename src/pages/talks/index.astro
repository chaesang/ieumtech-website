---
import Base from '~/layouts/Base.astro';
import { getCollection } from 'astro:content';

const enEntries = (await getCollection('talks', (e) => !e.data.draft && e.data.lang === 'en'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const isKoFallback = enEntries.length === 0;
const entries = isKoFallback
  ? (await getCollection('talks', (e) => !e.data.draft && e.data.lang === 'ko'))
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  : enEntries;
const basePath = isKoFallback ? '/ko/talks' : '/talks';
---
<Base
  title="Talks & Lectures — Chaesang Jung"
  description="Talks, interviews, podcasts, and lectures — words left along the way."
  lang="en"
  path="/talks"
  ogType="website"
  altLangPath="/ko/talks"
>
  <main>
    <section class="list-hero">
      <div class="container">
        <h1>Talks & Lectures</h1>
        <p class="list-lead">Talks, interviews, podcasts, lectures — words left along the way.</p>
        {isKoFallback && (
          <p class="notice">Currently in Korean. English entries will follow.</p>
        )}
      </div>
    </section>
    <section class="list-body">
      <div class="container">
        {entries.length === 0 ? (
          <p class="empty">No entries yet.</p>
        ) : (
          <ol class="talk-list">
            {entries.map((e) => {
              const slug = e.slug.split('/').pop()!;
              const d = e.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
              return (
                <li>
                  <a href={`${basePath}/${slug}`}>
                    <div class="talk-head">
                      <span class="talk-format" data-format={e.data.format}>{e.data.format}</span>
                      <span class="talk-date">{d}</span>
                    </div>
                    <div class="talk-title">{e.data.title}</div>
                    <div class="talk-venue">{e.data.venue} · {e.data.event}</div>
                  </a>
                </li>
              );
            })}
          </ol>
        )}
      </div>
    </section>
  </main>
</Base>

<style>
  .list-hero { padding: 64px 0 24px; border-bottom: 1px solid var(--color-border); }
  .list-hero h1 { font-size: 2rem; margin: 0 0 10px; }
  .list-lead { font-size: 1rem; color: var(--color-muted); max-width: 640px; margin: 0; line-height: 1.7; }
  .notice { font-size: 0.8125rem; color: var(--color-muted); margin-top: 12px; padding: 8px 12px; background: var(--color-border); border-radius: 4px; display: inline-block; }
  .list-body { padding: 32px 0 80px; }
  .empty { color: var(--color-muted); padding: 32px 0; text-align: center; }
  .talk-list { list-style: none; padding: 0; margin: 0; }
  .talk-list li { border-top: 1px solid var(--color-border); }
  .talk-list li:last-child { border-bottom: 1px solid var(--color-border); }
  .talk-list a { display: block; padding: 20px 0; color: inherit; text-decoration: none; }
  .talk-list a:hover .talk-title { color: var(--color-accent); }
  .talk-head { display: flex; gap: 12px; align-items: center; font-size: 0.8125rem; color: var(--color-muted); margin-bottom: 6px; }
  .talk-format { text-transform: capitalize; }
  .talk-title { font-size: 1.125rem; font-weight: 600; line-height: 1.4; margin-bottom: 6px; }
  .talk-venue { font-size: 0.875rem; color: var(--color-muted); }
</style>
