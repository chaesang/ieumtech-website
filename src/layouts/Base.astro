---
import '~/styles/global.css';
import type { Lang } from '~/i18n/ui';
import SEO from '~/components/SEO.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import SearchModal from '~/components/SearchModal.astro';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  path: string;
  ogType?: 'website' | 'article' | 'profile';
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalOverride?: string;
  jsonLd?: Record<string, unknown>;
  altLangPath?: string;
}

const {
  title,
  description,
  lang,
  path,
  ogType,
  ogImage,
  ogTitle,
  ogDescription,
  canonicalOverride,
  jsonLd,
  altLangPath,
} = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title={title}
      description={description}
      lang={lang}
      path={path}
      ogType={ogType}
      ogImage={ogImage}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      canonicalOverride={canonicalOverride}
      jsonLd={jsonLd}
    />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />
    <slot name="head" />
  </head>
  <body>
    <Header lang={lang} currentPath={path} altLangPath={altLangPath} />
    <slot />
    <Footer lang={lang} currentPath={path} />
    <SearchModal lang={lang} />
    <script>
      const HASH_PREFIXES = ['#series-', '#co-', '#talk-', '#project-'];

      function revealHashTarget() {
        const hash = window.location.hash;
        if (!hash || !HASH_PREFIXES.some((p) => hash.startsWith(p))) return;
        const el = document.querySelector(hash) as HTMLElement | null;
        if (!el) return;

        const details = el.tagName === 'DETAILS' ? (el as HTMLDetailsElement) : el.closest('details');
        if (details) details.open = true;

        requestAnimationFrame(() => {
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          el.classList.add('hash-highlight');
          window.setTimeout(() => el.classList.remove('hash-highlight'), 1800);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', revealHashTarget);
      } else {
        revealHashTarget();
      }
      window.addEventListener('hashchange', revealHashTarget);
    </script>
    <style is:global>
      .hash-highlight {
        animation: hashHighlight 1.6s ease-out;
      }
      @keyframes hashHighlight {
        0%   { background-color: var(--color-accent-soft, #e0e7ff); }
        100% { background-color: transparent; }
      }
    </style>
  </body>
</html>
