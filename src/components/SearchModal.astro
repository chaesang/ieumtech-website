---
import type { Lang } from '~/i18n/ui';
import { useTranslations } from '~/i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const indexUrl = lang === 'ko' ? '/ko/search-index.json' : '/search-index.json';
const searchPagePath = lang === 'ko' ? '/ko/search' : '/search';

const groupLabels = {
  writing: t('search.group.writing'),
  talks: t('search.group.talks'),
  projects: t('search.group.projects'),
  companies: t('search.group.companies'),
  about: t('search.group.about'),
};
---
<div
  class="search-modal"
  id="search-modal"
  data-index-url={indexUrl}
  data-search-page={searchPagePath}
  data-lang={lang}
  data-label-writing={groupLabels.writing}
  data-label-talks={groupLabels.talks}
  data-label-projects={groupLabels.projects}
  data-label-companies={groupLabels.companies}
  data-label-about={groupLabels.about}
  data-label-empty={t('search.empty')}
  data-label-no-results={t('search.noResults')}
  data-label-see-all={t('search.seeAll')}
  hidden
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label={t('search.label')}
>
  <div class="search-backdrop" data-search-close></div>
  <div class="search-card" role="document">
    <div class="search-input-row">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
      <input
        type="search"
        id="search-input"
        class="search-input"
        placeholder={t('search.placeholder')}
        autocomplete="off"
        spellcheck="false"
        aria-label={t('search.placeholder')}
      />
      <button type="button" class="search-close-btn" data-search-close aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <div class="search-results" id="search-results" role="listbox"></div>
    <div class="search-footer">
      <span><kbd>↑</kbd><kbd>↓</kbd> {lang === 'ko' ? '이동' : 'Navigate'}</span>
      <span><kbd>↵</kbd> {lang === 'ko' ? '열기' : 'Open'}</span>
      <span><kbd>Esc</kbd> {lang === 'ko' ? '닫기' : 'Close'}</span>
    </div>
  </div>
</div>

<script>
  import MiniSearch from 'minisearch';

  type SearchItem = {
    id: string;
    type: 'writing' | 'talks' | 'projects' | 'companies' | 'about';
    title: string;
    summary?: string;
    body?: string;
    tags?: string[];
    date?: string;
    url: string;
    external: boolean;
    source?: string;
    series?: string;
    seriesTitle?: string;
    lang: 'ko' | 'en';
  };

  const modal = document.getElementById('search-modal') as HTMLElement | null;
  if (modal) {
    const indexUrl = modal.dataset.indexUrl!;
    const searchPagePath = modal.dataset.searchPage!;
    const labels = {
      writing: modal.dataset.labelWriting!,
      talks: modal.dataset.labelTalks!,
      projects: modal.dataset.labelProjects!,
      companies: modal.dataset.labelCompanies!,
      about: modal.dataset.labelAbout!,
      empty: modal.dataset.labelEmpty!,
      noResults: modal.dataset.labelNoResults!,
      seeAll: modal.dataset.labelSeeAll!,
    };
    const input = document.getElementById('search-input') as HTMLInputElement;
    const resultsEl = document.getElementById('search-results') as HTMLElement;

    let items: SearchItem[] = [];
    let mini: MiniSearch<SearchItem> | null = null;
    let loadPromise: Promise<void> | null = null;
    let highlightedIndex = -1;
    let lastTrigger: HTMLElement | null = null;
    const groupOrder: Array<SearchItem['type']> = ['writing', 'talks', 'projects', 'companies', 'about'];

    async function loadIndex() {
      if (loadPromise) return loadPromise;
      loadPromise = (async () => {
        const res = await fetch(indexUrl);
        items = (await res.json()) as SearchItem[];
        mini = new MiniSearch<SearchItem>({
          fields: ['title', 'summary', 'body', 'tags', 'seriesTitle', 'source', 'aliases'],
          storeFields: ['id'],
          searchOptions: {
            boost: { title: 3, aliases: 2, seriesTitle: 1.5, summary: 1.2 },
            prefix: true,
            fuzzy: 0.2,
            combineWith: 'AND',
          },
          extractField: (doc, field) => {
            const v = (doc as Record<string, unknown>)[field];
            if (Array.isArray(v)) return v.join(' ');
            return (v as string) ?? '';
          },
        });
        mini.addAll(items);
      })();
      return loadPromise;
    }

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function renderEmpty() {
      resultsEl.innerHTML = `<div class="search-state">${escapeHtml(labels.empty)}</div>`;
      highlightedIndex = -1;
    }

    function renderNoResults(query: string) {
      resultsEl.innerHTML = `<div class="search-state">${escapeHtml(labels.noResults)}</div>`;
      highlightedIndex = -1;
    }

    function renderResults(query: string, hits: SearchItem[]) {
      const grouped = new Map<SearchItem['type'], SearchItem[]>();
      for (const t of groupOrder) grouped.set(t, []);
      for (const h of hits) grouped.get(h.type)!.push(h);

      const MAX_PER_GROUP = 5;
      const TOTAL_CAP = 20;
      let totalShown = 0;
      const html: string[] = [];
      let flatIndex = 0;
      const flatItems: SearchItem[] = [];

      for (const type of groupOrder) {
        const list = grouped.get(type)!;
        if (list.length === 0) continue;
        const visible = list.slice(0, MAX_PER_GROUP);
        if (totalShown + visible.length > TOTAL_CAP) {
          visible.splice(TOTAL_CAP - totalShown);
          if (visible.length === 0) break;
        }
        totalShown += visible.length;

        html.push(`<div class="search-group"><div class="search-group-label">${escapeHtml(labels[type])}<span class="search-group-count">${list.length}</span></div>`);
        for (const item of visible) {
          const meta: string[] = [];
          if (item.seriesTitle) meta.push(escapeHtml(item.seriesTitle));
          if (item.source) meta.push(escapeHtml(item.source));
          if (item.date) meta.push(escapeHtml(item.date));
          const metaHtml = meta.length ? `<span class="search-meta">${meta.join(' · ')}</span>` : '';
          const externalIcon = item.external ? '<span class="search-external" aria-hidden="true">↗</span>' : '';
          const summary = item.summary ? `<div class="search-summary">${escapeHtml(item.summary)}</div>` : '';
          html.push(`
            <a class="search-result" data-index="${flatIndex}" href="${escapeHtml(item.url)}"${item.external ? ' target="_blank" rel="noopener noreferrer"' : ''}>
              <div class="search-result-title">${escapeHtml(item.title)}${externalIcon}</div>
              ${summary}
              ${metaHtml}
            </a>
          `);
          flatItems.push(item);
          flatIndex++;
        }
        html.push('</div>');
      }

      const seeAllHref = `${searchPagePath}?q=${encodeURIComponent(query)}`;
      html.push(`<a class="search-see-all" href="${seeAllHref}">${escapeHtml(labels.seeAll)} →</a>`);

      resultsEl.innerHTML = html.join('');
      (resultsEl as any)._flatItems = flatItems;
      highlightedIndex = flatItems.length > 0 ? 0 : -1;
      updateHighlight();
    }

    function updateHighlight() {
      const els = resultsEl.querySelectorAll<HTMLElement>('.search-result');
      els.forEach((el, i) => {
        if (i === highlightedIndex) {
          el.classList.add('highlighted');
          el.scrollIntoView({ block: 'nearest' });
        } else {
          el.classList.remove('highlighted');
        }
      });
    }

    function performSearch(query: string) {
      const q = query.trim();
      if (!q) {
        renderEmpty();
        return;
      }
      if (!mini) return;
      const ids = new Set(mini.search(q).map((r) => r.id as string));
      const hits = items.filter((it) => ids.has(it.id));
      if (hits.length === 0) {
        renderNoResults(q);
      } else {
        renderResults(q, hits);
      }
    }

    function openModal(triggerEl?: HTMLElement) {
      lastTrigger = triggerEl ?? (document.activeElement as HTMLElement | null);
      modal!.hidden = false;
      modal!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      input.value = '';
      renderEmpty();
      loadIndex();
      requestAnimationFrame(() => input.focus());
    }

    function closeModal() {
      modal!.hidden = true;
      modal!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (lastTrigger && typeof lastTrigger.focus === 'function') {
        lastTrigger.focus();
      }
    }

    (window as any).__ieumOpenSearch = openModal;

    document.addEventListener('keydown', (e) => {
      const isMac = navigator.platform.toUpperCase().includes('MAC');
      const cmdK = (isMac ? e.metaKey : e.ctrlKey) && e.key.toLowerCase() === 'k';
      if (cmdK) {
        e.preventDefault();
        if (modal!.hidden) openModal();
        else closeModal();
        return;
      }
      if (modal!.hidden) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        closeModal();
        return;
      }
      const flatItems: SearchItem[] = (resultsEl as any)._flatItems ?? [];
      if (e.key === 'ArrowDown') {
        if (flatItems.length === 0) return;
        e.preventDefault();
        highlightedIndex = (highlightedIndex + 1) % flatItems.length;
        updateHighlight();
      } else if (e.key === 'ArrowUp') {
        if (flatItems.length === 0) return;
        e.preventDefault();
        highlightedIndex = (highlightedIndex - 1 + flatItems.length) % flatItems.length;
        updateHighlight();
      } else if (e.key === 'Enter') {
        if (flatItems.length === 0 || highlightedIndex < 0) return;
        const el = resultsEl.querySelectorAll<HTMLAnchorElement>('.search-result')[highlightedIndex];
        if (el) {
          e.preventDefault();
          el.click();
        }
      }
    });

    modal!.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('[data-search-close]')) {
        closeModal();
      }
    });

    let debounceId: number | undefined;
    input.addEventListener('input', () => {
      const q = input.value;
      window.clearTimeout(debounceId);
      debounceId = window.setTimeout(() => {
        loadIndex().then(() => performSearch(q));
      }, 80);
    });
  }
</script>

<style is:global>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 10vh 16px 16px;
  }
  .search-modal[hidden] { display: none; }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 15, 15, 0.45);
    backdrop-filter: blur(4px);
  }

  .search-card {
    position: relative;
    width: 100%;
    max-width: 640px;
    background: var(--color-surface, #fff);
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 12px;
    box-shadow: 0 24px 56px rgba(0, 0, 0, 0.18);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 80vh;
  }

  .search-input-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-border, #e5e5e5);
  }
  .search-icon {
    color: var(--color-subtle, #888);
    flex-shrink: 0;
  }
  .search-input {
    flex: 1;
    border: none;
    outline: none;
    font: inherit;
    font-size: 1rem;
    background: transparent;
    color: var(--color-text, #111);
    min-width: 0;
  }
  .search-input::-webkit-search-cancel-button { display: none; }
  .search-close-btn {
    background: transparent;
    border: none;
    color: var(--color-subtle, #888);
    cursor: pointer;
    padding: 4px;
    display: inline-flex;
    align-items: center;
    border-radius: 4px;
  }
  .search-close-btn:hover { color: var(--color-text, #111); background: var(--color-surface-2, #f5f5f5); }

  .search-results {
    overflow-y: auto;
    flex: 1;
    padding: 8px 0;
  }

  .search-state {
    padding: 24px 20px;
    color: var(--color-subtle, #888);
    font-size: 0.9rem;
    text-align: center;
  }

  .search-group {
    padding: 4px 0;
  }
  .search-group-label {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 8px 20px 4px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-subtle, #888);
  }
  .search-group-count {
    font-weight: 400;
    color: var(--color-subtle, #aaa);
  }

  .search-result {
    display: block;
    padding: 10px 20px;
    color: inherit;
    text-decoration: none;
    border-left: 2px solid transparent;
  }
  .search-result[target="_blank"]::after { content: none; }
  .search-result:hover,
  .search-result.highlighted {
    background: var(--color-surface-2, #f6f6f6);
    border-left-color: var(--color-accent, #2962ff);
  }
  .search-result-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text, #111);
    line-height: 1.4;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .search-external {
    font-size: 0.75rem;
    color: var(--color-subtle, #888);
  }
  .search-summary {
    margin-top: 2px;
    font-size: 0.825rem;
    color: var(--color-muted, #555);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .search-meta {
    display: block;
    margin-top: 4px;
    font-size: 0.75rem;
    color: var(--color-subtle, #888);
  }

  .search-see-all {
    display: block;
    text-align: center;
    padding: 12px;
    margin: 8px 12px 4px;
    font-size: 0.85rem;
    color: var(--color-accent, #2962ff);
    text-decoration: none;
    border-top: 1px solid var(--color-border, #e5e5e5);
  }
  .search-see-all:hover { background: var(--color-surface-2, #f6f6f6); }

  .search-footer {
    display: flex;
    gap: 16px;
    padding: 10px 16px;
    border-top: 1px solid var(--color-border, #e5e5e5);
    font-size: 0.75rem;
    color: var(--color-subtle, #888);
    background: var(--color-surface-2, #fafafa);
    flex-wrap: wrap;
  }
  .search-footer kbd {
    display: inline-block;
    padding: 1px 5px;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 3px;
    background: var(--color-surface, #fff);
    font-family: inherit;
    font-size: 0.7rem;
    margin-right: 4px;
  }

  @media (max-width: 639px) {
    .search-modal { padding: 4vh 8px 8px; }
    .search-card { max-height: 92vh; }
    .search-footer { display: none; }
  }
</style>
