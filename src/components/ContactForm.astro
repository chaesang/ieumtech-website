---
import type { Lang } from '~/i18n/ui';
import { useTranslations } from '~/i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const ACCESS_KEY = 'fb98ecd5-455b-459f-b876-9eb7c9911118';
---
<form id="contact-form" class="contact-form" data-lang={lang}>
  <input type="hidden" name="access_key" value={ACCESS_KEY} />
  <input type="hidden" name="from_name" value="ieumtech.net" />
  <input type="hidden" name="subject" value="이음 테크 새 문의 / Ieum Tech inquiry" />
  <input type="text" name="botcheck" tabindex="-1" autocomplete="off" class="contact-honeypot" aria-hidden="true" />

  <div class="contact-field">
    <label for="cf-name">{t('contact.field.name')} <span class="required" aria-hidden="true">*</span></label>
    <input id="cf-name" type="text" name="name" required autocomplete="name" />
  </div>

  <div class="contact-field">
    <label for="cf-email">{t('contact.field.email')} <span class="required" aria-hidden="true">*</span></label>
    <input id="cf-email" type="email" name="email" required autocomplete="email" />
    <small>{t('contact.field.email.help')}</small>
  </div>

  <div class="contact-field">
    <span class="contact-fieldset-label">{t('contact.field.topic')} <span class="required" aria-hidden="true">*</span></span>
    <div class="contact-radios" role="radiogroup">
      <label class="contact-radio">
        <input type="radio" name="topic" value={lang === 'ko' ? '조직 자문' : 'Organizational advisory'} required />
        <span>{t('contact.field.topic.advisory')}</span>
      </label>
      <label class="contact-radio">
        <input type="radio" name="topic" value={lang === 'ko' ? '강연·강의' : 'Talks & lectures'} />
        <span>{t('contact.field.topic.talks')}</span>
      </label>
      <label class="contact-radio">
        <input type="radio" name="topic" value={lang === 'ko' ? '기타' : 'Other'} />
        <span>{t('contact.field.topic.other')}</span>
      </label>
    </div>
  </div>

  <div class="contact-field">
    <label for="cf-message">{t('contact.field.message')} <span class="required" aria-hidden="true">*</span></label>
    <textarea id="cf-message" name="message" required rows="6"></textarea>
    <small>{t('contact.field.message.help')}</small>
  </div>

  <div class="contact-field">
    <label for="cf-affiliation">{t('contact.field.affiliation')}</label>
    <input id="cf-affiliation" type="text" name="affiliation" autocomplete="organization" />
    <small>{t('contact.field.affiliation.help')}</small>
  </div>

  <div class="contact-submit-row">
    <button type="submit" class="btn contact-submit">
      <span class="contact-submit-label" data-default-label={t('contact.submit')} data-loading-label={t('contact.submitting')}>{t('contact.submit')}</span>
    </button>
    <span class="contact-error" id="contact-error" role="alert" hidden>{t('contact.error')}</span>
  </div>
</form>

<div id="contact-success" class="contact-success" hidden>
  <h2>{t('contact.success.title')}</h2>
  <p>{t('contact.success.body')}</p>
  <p class="contact-signoff">{t('contact.success.signoff')}</p>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('contact-success') as HTMLElement | null;
  const errorEl = document.getElementById('contact-error') as HTMLElement | null;

  if (form && success && errorEl) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.hidden = true;

      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const labelEl = form.querySelector<HTMLElement>('.contact-submit-label');
      if (submitBtn && labelEl) {
        submitBtn.disabled = true;
        labelEl.textContent = labelEl.dataset.loadingLabel ?? 'Sending…';
      }

      const formData = new FormData(form);
      const topic = formData.get('topic');
      if (topic) {
        formData.set('subject', `이음 테크 새 문의 — ${topic}`);
      }

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.success) {
          if (submitBtn && labelEl) {
            submitBtn.disabled = false;
            labelEl.textContent = labelEl.dataset.defaultLabel ?? 'Send';
          }
          form.hidden = true;
          success.hidden = false;
          success.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } else {
          throw new Error(data.message ?? 'request failed');
        }
      } catch (err) {
        errorEl.hidden = false;
        if (submitBtn && labelEl) {
          submitBtn.disabled = false;
          labelEl.textContent = labelEl.dataset.defaultLabel ?? 'Send';
        }
      }
    });
  }
</script>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: 560px;
  }
  .contact-form[hidden] { display: none; }

  .contact-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .contact-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .contact-field label,
  .contact-fieldset-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.005em;
  }
  .contact-field .required {
    color: var(--color-accent);
    font-weight: 400;
  }
  .contact-field small {
    font-size: 0.8125rem;
    color: var(--color-subtle);
    line-height: 1.5;
  }

  .contact-field input[type="text"],
  .contact-field input[type="email"],
  .contact-field textarea {
    font: inherit;
    font-size: 0.9375rem;
    padding: 10px 12px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-surface);
    color: var(--color-text);
    transition: border-color var(--transition-base);
  }
  .contact-field input:focus,
  .contact-field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .contact-field textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.6;
  }

  .contact-radios {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .contact-radio {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    cursor: pointer;
    transition: border-color var(--transition-base), background var(--transition-base);
    font-weight: 400 !important;
    font-size: 0.9375rem;
    line-height: 1.5;
  }
  .contact-radio:hover {
    border-color: var(--color-subtle);
  }
  .contact-radio input[type="radio"] {
    margin-top: 3px;
    flex-shrink: 0;
  }
  .contact-radio:has(input:checked) {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .contact-submit-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-2);
  }
  .contact-submit {
    min-width: 140px;
  }
  .contact-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .contact-error {
    font-size: 0.875rem;
    color: #c2410c;
    line-height: 1.5;
  }

  .contact-success {
    max-width: 560px;
    padding: var(--space-6);
    border-left: 3px solid var(--color-accent);
    background: var(--color-surface);
  }
  .contact-success h2 {
    font-size: 1.25rem;
    margin: 0 0 var(--space-3);
    letter-spacing: -0.01em;
  }
  .contact-success p {
    margin: 0 0 var(--space-2);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
    white-space: pre-line;
  }
  .contact-signoff {
    margin-top: var(--space-3) !important;
    color: var(--color-muted) !important;
    font-size: 0.9375rem !important;
  }
</style>
